---
import { SITE_TITLE } from '../consts';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const productMenu = [
	{ label: 'менторство по карьере', href: `${base}/wiki/mentoring/` },
	{ label: 'CV', href: `${base}/CV/` },
	{ label: 'портфолио кейсов', href: `${base}/wiki/portfolio/` },
	{ label: 'чтобы лучше понимать вову', href: 'https://tender-show-a65.notion.site/4f293576cd1a434ca700c64b96f766e1?source=copy_link', external: true },
];
const creativeMenu = [
	{ label: '#театр', href: `${base}/tags/${encodeURIComponent('театр')}/` },
	{ label: '#танцы', href: `${base}/tags/${encodeURIComponent('танцы')}/` },
	{ label: '#творчество', href: `${base}/tags/${encodeURIComponent('творчество')}/` },
	{ label: '#безумие', href: `${base}/tags/${encodeURIComponent('безумие')}/` },
];
---

<header class="site-header" id="site-header">
	<div class="inner">
		<a class="brand" href={`${base}/`}>
			<img src={`${base}/avatar_pio.png`} alt="pio" />
			<span>{SITE_TITLE}</span>
		</a>
		<nav>
			<div class="nav-dd">
				<button class="nav-dd-trigger" aria-expanded="false">продукт</button>
				<div class="nav-dd-menu">
					{productMenu.map((item) => (
						item.external
							? <a href={item.href} target="_blank" rel="noopener" class="external">{item.label}</a>
							: <a href={item.href}>{item.label}</a>
					))}
				</div>
			</div>
			<a href={`${base}/useful/`}>полезность</a>
			<div class="nav-dd">
				<button class="nav-dd-trigger" aria-expanded="false">творчество</button>
				<div class="nav-dd-menu">
					{creativeMenu.map((item) => (
						<a href={item.href}>{item.label}</a>
					))}
				</div>
			</div>
			<a href={`${base}/photos/`}>фото</a>
			<a href={`${base}/archive/`}>архив</a>
			<a href={`${base}/tags/`}>теги</a>
			<a href={`${base}/graph/`}>граф</a>
		</nav>
	</div>
</header>

<script is:inline>
	(() => {
		// Compact navbar on scroll (>50px)
		const header = document.getElementById('site-header');
		if (header) {
			let ticking = false;
			const onScroll = () => {
				if (ticking) return;
				ticking = true;
				requestAnimationFrame(() => {
					header.classList.toggle('scrolled', window.scrollY > 50);
					ticking = false;
				});
			};
			window.addEventListener('scroll', onScroll, { passive: true });
		}

		// Dropdown click-to-toggle
		const triggers = document.querySelectorAll('.nav-dd-trigger');
		const closeAll = () => {
			document.querySelectorAll('.nav-dd.open').forEach((d) => {
				d.classList.remove('open');
				const t = d.querySelector('.nav-dd-trigger');
				if (t) t.setAttribute('aria-expanded', 'false');
			});
		};
		triggers.forEach((t) => {
			t.addEventListener('click', (e) => {
				e.preventDefault();
				e.stopPropagation();
				const dd = t.closest('.nav-dd');
				const wasOpen = dd.classList.contains('open');
				closeAll();
				if (!wasOpen) {
					dd.classList.add('open');
					t.setAttribute('aria-expanded', 'true');
				}
			});
		});
		document.addEventListener('click', (e) => {
			if (!e.target.closest('.nav-dd')) closeAll();
		});
		document.addEventListener('keydown', (e) => {
			if (e.key === 'Escape') closeAll();
		});
	})();
</script>
