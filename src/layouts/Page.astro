---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';

type RelatedWiki = {
	id: string;
	title: string;
	thumbStyle?: string;
};

interface Props {
	title: string;
	description?: string;
	relatedWiki?: RelatedWiki[];
}
const { title, description = '', relatedWiki = [] } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!doctype html>
<html lang="ru">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body>
		<Header />
		<main class="content wiki-page" data-pagefind-body>
			<h1>{title}</h1>
			<div class="page-content">
				<slot />
			</div>

			{relatedWiki.length > 0 && (
				<aside class="related-posts wiki-related">
					<details class="wiki-related-toggle">
						<summary>
							<span class="label">другие странички вики</span>
							<span class="count">{relatedWiki.length}</span>
						</summary>
						<div class="related-grid">
							{relatedWiki.map((r) => (
								<a class="related-card" href={`${base}/wiki/${r.id}/`}>
									<span class="thumb" aria-hidden="true" style={r.thumbStyle}></span>
									<span class="body">
										<span class="ttl">{r.title}</span>
									</span>
								</a>
							))}
						</div>
					</details>
				</aside>
			)}
		</main>
		<Footer />
		<script is:inline>
			/* Внешние ссылки в notion-контенте — в новой вкладке.
			   Внутренние (тот же host) оставляем как есть, чтоб не плодить вкладки
			   при навигации по вики. */
			document.querySelectorAll('.page-content a[href]').forEach((a) => {
				const href = a.getAttribute('href');
				if (!href || !/^https?:\/\//i.test(href)) return;
				try {
					if (new URL(href).host !== location.host) {
						a.setAttribute('target', '_blank');
						a.setAttribute('rel', 'noopener noreferrer');
					}
				} catch {}
			});
		</script>
	</body>
</html>
