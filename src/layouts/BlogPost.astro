---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import metricsData from '../data/metrics.json';
import { formatCount, formatErr } from '../lib/format';

type PostMetrics = {
	views: number;
	forwards: number;
	replies: number;
	reactions: { emoji: string; count: number }[];
	err: number | null;
	last_updated: string;
};
const metrics: Record<string, PostMetrics> = metricsData as any;

type Neighbor = { id: string; title: string; pubDate: Date } | null;
type MiniGraph = {
	nodes: { id: string; title: string; primaryTag: string; date: string }[];
	links: { source: string; target: string }[];
};
type SeriesPart = { id: string; title: string; part: number };
type SeriesData = {
	slug: string;
	name: string;
	introSlug: string | null;
	parts: SeriesPart[];
	currentPart: number;
	nextSibling: SeriesPart | null;
} | null;
type RelatedPost = {
	id: string;
	title: string;
	heroImage: string;
	pubDate: Date;
	sharedTags: string[];
};
type Props = CollectionEntry<'blog'>['data'] & {
	prev?: Neighbor;
	next?: Neighbor;
	related?: RelatedPost[];
	miniGraph?: MiniGraph;
	series?: SeriesData;
	tgMessageId?: number | null;
	excerpt?: string;
};

const { title, pubDate, updatedDate, heroImage, tags, prev, next, related, miniGraph, series, tgMessageId, excerpt } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const showMini = miniGraph && miniGraph.nodes.length > 1;
const miniCount = showMini ? miniGraph.nodes.length - 1 : 0;
const showTgPill = !!tgMessageId;
const showHero = heroImage && !heroImage.startsWith('/img/og/gradients/');

// Метрики по tgMessageId — рендерим если есть запись в metrics.json
const postMetrics = tgMessageId ? metrics[String(tgMessageId)] : null;
const reactionsTotal = postMetrics
	? postMetrics.reactions.reduce((s, r) => s + r.count, 0)
	: 0;
const topReactions = postMetrics
	? postMetrics.reactions.slice(0, 3).map((r) => `${r.emoji} ${r.count}`).join(' · ')
	: '';
---

<!doctype html>
<html lang="ru">
	<head>
		<BaseHead title={title} description={excerpt ?? title} image={heroImage} ogType="article" publishedTime={pubDate} />
	</head>
	<body>
		<Header />
		<main class="content">
			<article data-pagefind-body>
				<header class="post-header">
					<h1>{title}</h1>
					<div class="post-date">
						<FormattedDate date={pubDate} />
						{updatedDate && <span> · обновлено <FormattedDate date={updatedDate} /></span>}
					</div>
					{tags && tags.length > 0 && (
						<div class="post-tags">
							{tags.map((tag) => (
								<a href={`${base}/tags/${encodeURIComponent(tag)}/`}>{tag}</a>
							))}
						</div>
					)}
				</header>

				{series && (
					<aside class="series-nav">
						<span class="name">📚 {series.name}</span>
						<div class="pills">
							{series.parts.map((p) => {
								const label = p.part === 0 ? 'intro' : `часть ${p.part}`;
								if (p.part === series.currentPart) return <span class="pill current">{label}</span>;
								return <a class="pill" href={`${base}/blog/${p.id}/`} title={p.title}>{label}</a>;
							})}
						</div>
					</aside>
				)}

				<div class="post-content">
					<slot />
				</div>

				{showHero && (
					<figure class="post-hero">
						<img src={heroImage} alt="" loading="eager" />
					</figure>
				)}

				{series && series.nextSibling && (
					<a href={`${base}/blog/${series.nextSibling.id}/`} class="series-cta">
						<div>
							<div class="lbl">{series.currentPart === 0 ? 'Начать с части 1' : 'Следующая часть в серии'}</div>
							<div class="ttl">{series.nextSibling.title}</div>
						</div>
						<span class="arrow">→</span>
					</a>
				)}

				{postMetrics && (
					<aside class="post-metrics" aria-label="метрики поста">
						<span class="m" title={`${postMetrics.views} просмотров`}>{formatCount(postMetrics.views)} 👁</span>
						{reactionsTotal > 0 && (
							<span class="m" title={topReactions}>{formatCount(reactionsTotal)} 🐳</span>
						)}
						{postMetrics.forwards > 0 && (
							<span class="m" title={`${postMetrics.forwards} пересылок`}>{formatCount(postMetrics.forwards)} ↗</span>
						)}
						{postMetrics.err != null && (
							<span class="m" title="(реакции + пересылки + ответы) / просмотры">ERR {formatErr(postMetrics.err)}</span>
						)}
					</aside>
				)}

				{related && related.length > 0 && (
					<aside class="related-posts">
						<h3>Похожие посты</h3>
						<div class="related-grid">
							{related.map((r) => {
								const initial = (r.title || '?').trim().charAt(0).toUpperCase();
								const visibleTags = (r.sharedTags || []).slice(0, 2);
								return (
									<a class="related-card" href={`${base}/blog/${r.id}/`}>
										{r.heroImage ? (
											<span class="thumb" style={`background-image:url('${r.heroImage}')`} aria-hidden="true"></span>
										) : (
											<span class="thumb thumb-fallback" aria-hidden="true">{initial}</span>
										)}
										<span class="body">
											<span class="ttl">{r.title}</span>
											<span class="meta">
												<span class="d"><FormattedDate date={r.pubDate} short /></span>
												{visibleTags.length > 0 && (
													<span class="tag-pills">
														{visibleTags.map((t) => <span class="pill">{t}</span>)}
													</span>
												)}
											</span>
										</span>
									</a>
								);
							})}
						</div>
					</aside>
				)}

				{/* prev/next временно скрыты — навигация через related/archive/tags */}

				{(showMini || showTgPill) && (
					<aside class="mini-graph-wrap">
						<div class="post-actions-row">
							{showMini && (
								<details class="conn-toggle">
									<summary>
										<span class="label">показать связи поста</span>
										<span class="count">{miniCount}</span>
									</summary>
								</details>
							)}
							{showTgPill && (
								<a class="tg-pill" href={`https://t.me/pioblog/${tgMessageId}`} target="_blank" rel="noopener" aria-label="Читать в Telegram">
									<svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M9.78 18.65l.28-4.23 7.68-6.92c.34-.31-.07-.46-.52-.19l-9.49 5.99-4.1-1.28c-.88-.25-.89-.86.2-1.3l15.97-6.16c.73-.33 1.43.18 1.15 1.31l-2.72 12.81c-.19.91-.74 1.13-1.5.71l-4.07-3-1.96 1.93c-.23.23-.42.42-.84.42z"/></svg>
									<span class="label">читать в Telegram</span>
								</a>
							)}
						</div>
						{showMini && <div class="mini-graph" id="mini-graph"></div>}
					</aside>
				)}
			</article>
		</main>
		<Footer />

		{showMini && (
			<>
				<script src="https://cdn.jsdelivr.net/npm/force-graph@1.49.5/dist/force-graph.min.js" is:inline></script>
				<script define:vars={{ DATA: miniGraph, BASE: base }} is:inline>
					const palette = {
						'продакт':'#ff4200','карьера':'#e11d48','школа жизни':'#f59e0b',
						'вуз':'#1e40af','трипы':'#10b981','рефлексия':'#8b5cf6',
						'психология':'#a855f7','нетворкинг':'#06b6d4','безумие':'#ec4899',
						'театр':'#f43f5e','ии':'#0ea5e9','анонс':'#14b8a6','боты':'#22c55e',
						'танцы':'#d946ef','творчество':'#eab308','жизнь':'#84cc16',
						'друзья':'#f97316','мнения':'#64748b',
					};
					const getCss = (name) => getComputedStyle(document.documentElement).getPropertyValue(name).trim();
					const el = document.getElementById('mini-graph');
					const details = document.querySelector('.mini-graph-wrap .conn-toggle');
					const center = DATA.nodes[0]?.id;
					let fg = null;

					function init() {
						if (fg) return;
						fg = ForceGraph()(el)
							.graphData({ nodes: DATA.nodes.map((n) => ({...n})), links: DATA.links.map((l) => ({...l})) })
							.backgroundColor('rgba(0,0,0,0)')
							.width(el.clientWidth)
							.height(360)
							.nodeRelSize(5)
							.nodeVal((n) => n.id === center ? 9 : 3)
							.nodeColor((n) => n.id === center ? getCss('--text-dark') : (palette[n.primaryTag] || getCss('--muted')))
							.linkColor(() => getCss('--graph-link'))
							.linkWidth(1)
							.nodeCanvasObjectMode(() => 'after')
							.nodeCanvasObject((node, ctx, scale) => {
								const isCenter = node.id === center;
								const baseFs = isCenter ? 12 : 10.5;
								const fontSize = baseFs / Math.max(scale, 0.7);
								const label = (node.title || node.id).slice(0, 32);
								ctx.font = (isCenter ? '700 ' : '500 ') + fontSize + 'px sans-serif';
								ctx.textAlign = 'center';
								ctx.textBaseline = 'middle';
								const tw = ctx.measureText(label).width;
								const r = isCenter ? 9 : 6;
								ctx.fillStyle = getCss('--graph-text-bg');
								ctx.fillRect(node.x - tw/2 - 4, node.y + r + 2, tw + 8, fontSize + 4);
								ctx.fillStyle = isCenter ? getCss('--text-dark') : getCss('--graph-text');
								ctx.fillText(label, node.x, node.y + r + 4 + fontSize * 0.5);
							})
							.nodeLabel((n) => n.title)
							.onNodeClick((n) => { if (n.id !== center) window.location.href = BASE + '/blog/' + n.id + '/'; })
							.cooldownTicks(120);
						setTimeout(() => {
							try {
								fg.d3Force('charge').strength(-380);
								fg.d3Force('link').distance(80);
								fg.d3ReheatSimulation();
							} catch(e) {}
						}, 50);
						fg.onEngineStop(() => fg.zoomToFit(400, 50));
						window.addEventListener('resize', () => fg && fg.width(el.clientWidth));
					}

					if (details && !details.open) {
						details.addEventListener('toggle', () => { if (details.open) init(); }, { once: true });
					} else {
						init();
					}
					window.addEventListener('themechange', () => { if (fg) fg.refresh(); });
				</script>
			</>
		)}
	</body>
</html>

<style is:global>
	/* Hero-image на странице поста — единая точка правды для картинки.
	   Раньше hero дублировался первым ![]() в body; теперь body чистое,
	   а картинка показывается тут. Не показываем для градиентных fallback. */
	/* Hero теперь не сверху, а в конце поста перед related-блоком —
	   как заключительная иллюстрация, не доминирует на первом экране. */
	.post-hero {
		margin: 2rem 0 0;
		padding: 0;
	}
	.post-hero img {
		display: block;
		max-width: 100%;
		height: auto;
		margin: 0 auto;
		border-radius: 6px;
		background: var(--border-soft);
	}

	/* Стили .related-posts вынесены в src/styles/global.css —
	   они нужны и на wiki/notion-страницах через layouts/Page.astro,
	   а <style is:global> здесь подгружается только на blog-страницах. */
</style>
