---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Neighbor = { id: string; title: string; pubDate: Date } | null;
type MiniGraph = {
	nodes: { id: string; title: string; primaryTag: string; date: string }[];
	links: { source: string; target: string }[];
};
type SeriesPart = { id: string; title: string; subtitle: string; part: number };
type SeriesData = {
	slug: string;
	name: string;
	introSlug: string | null;
	parts: SeriesPart[];
	currentPart: number;
	nextSibling: SeriesPart | null;
} | null;
type RelatedPost = {
	id: string;
	title: string;
	subtitle: string;
	heroImage: string;
	pubDate: Date;
	sharedTags: string[];
};
type Props = CollectionEntry<'blog'>['data'] & {
	prev?: Neighbor;
	next?: Neighbor;
	related?: RelatedPost[];
	miniGraph?: MiniGraph;
	series?: SeriesData;
};

const { title, subtitle, pubDate, updatedDate, heroImage, tags, prev, next, related, miniGraph, series } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const showMini = miniGraph && miniGraph.nodes.length > 1;
const miniCount = showMini ? miniGraph.nodes.length - 1 : 0;
---

<!doctype html>
<html lang="ru">
	<head>
		<BaseHead title={title} description={subtitle ?? title} image={heroImage} />
	</head>
	<body>
		<Header />
		<main class="content">
			<article>
				<header class="post-header">
					<div class="post-date">
						<FormattedDate date={pubDate} />
						{updatedDate && <span> · обновлено <FormattedDate date={updatedDate} /></span>}
					</div>
					<h1>{title}</h1>
					{subtitle && <p class="post-subtitle">{subtitle}</p>}
					{tags && tags.length > 0 && (
						<div class="post-tags">
							{tags.map((tag) => (
								<a href={`${base}/tags/${encodeURIComponent(tag)}/`}>{tag}</a>
							))}
						</div>
					)}
				</header>

				{series && (
					<aside class="series-nav">
						<span class="name">📚 {series.name}</span>
						<div class="pills">
							{series.parts.map((p) => {
								const label = p.part === 0 ? 'intro' : `часть ${p.part}`;
								if (p.part === series.currentPart) return <span class="pill current">{label}</span>;
								return <a class="pill" href={`${base}/blog/${p.id}/`} title={p.title}>{label}</a>;
							})}
						</div>
					</aside>
				)}

				<div class="post-content">
					<slot />
				</div>

				{related && related.length > 0 && (
					<aside class="related-posts">
						<h3>Похожие посты</h3>
						<div class="related-grid">
							{related.map((r) => {
								const initial = (r.title || '?').trim().charAt(0).toUpperCase();
								const visibleTags = (r.sharedTags || []).slice(0, 2);
								return (
									<a class="related-card" href={`${base}/blog/${r.id}/`}>
										{r.heroImage ? (
											<span class="thumb" style={`background-image:url('${r.heroImage}')`} aria-hidden="true"></span>
										) : (
											<span class="thumb thumb-fallback" aria-hidden="true">{initial}</span>
										)}
										<span class="body">
											<span class="ttl">{r.title}</span>
											<span class="meta">
												<span class="d"><FormattedDate date={r.pubDate} short /></span>
												{visibleTags.length > 0 && (
													<span class="tag-pills">
														{visibleTags.map((t) => <span class="pill">{t}</span>)}
													</span>
												)}
											</span>
										</span>
									</a>
								);
							})}
						</div>
					</aside>
				)}

				{series && series.nextSibling && (
					<a href={`${base}/blog/${series.nextSibling.id}/`} class="series-cta">
						<div>
							<div class="lbl">{series.currentPart === 0 ? 'Начать с части 1' : 'Следующая часть в серии'}</div>
							<div class="ttl">{series.nextSibling.title}</div>
						</div>
						<span class="arrow">→</span>
					</a>
				)}

				{/* prev/next временно скрыты — навигация через related/archive/tags */}

				{showMini && (
					<aside class="mini-graph-wrap">
						<details>
							<summary>
								<span class="label">показать связи поста</span>
								<span class="count">{miniCount}</span>
							</summary>
							<div class="mini-graph" id="mini-graph"></div>
						</details>
					</aside>
				)}
			</article>
		</main>
		<Footer />

		{showMini && (
			<>
				<script src="https://cdn.jsdelivr.net/npm/force-graph@1.49.5/dist/force-graph.min.js" is:inline></script>
				<script define:vars={{ DATA: miniGraph, BASE: base }} is:inline>
					const palette = {
						'продакт':'#ff4200','карьера':'#e11d48','школа жизни':'#f59e0b',
						'вуз':'#1e40af','трипы':'#10b981','рефлексия':'#8b5cf6',
						'психология':'#a855f7','нетворкинг':'#06b6d4','безумие':'#ec4899',
						'театр':'#f43f5e','ии':'#0ea5e9','анонс':'#14b8a6','боты':'#22c55e',
						'танцы':'#d946ef','творчество':'#eab308','жизнь':'#84cc16',
						'друзья':'#f97316','мнения':'#64748b',
					};
					const el = document.getElementById('mini-graph');
					const details = el.closest('details');
					const center = DATA.nodes[0]?.id;
					let fg = null;

					function init() {
						if (fg) return;
						fg = ForceGraph()(el)
							.graphData({ nodes: DATA.nodes.map((n) => ({...n})), links: DATA.links.map((l) => ({...l})) })
							.backgroundColor('rgba(0,0,0,0)')
							.width(el.clientWidth)
							.height(360)
							.nodeRelSize(5)
							.nodeVal((n) => n.id === center ? 9 : 3)
							.nodeColor((n) => n.id === center ? '#111' : (palette[n.primaryTag] || '#aaa'))
							.linkColor(() => 'rgba(120,120,120,0.45)')
							.linkWidth(1)
							.nodeCanvasObjectMode(() => 'after')
							.nodeCanvasObject((node, ctx, scale) => {
								const isCenter = node.id === center;
								const baseFs = isCenter ? 12 : 10.5;
								const fontSize = baseFs / Math.max(scale, 0.7);
								const label = (node.title || node.id).slice(0, 32);
								ctx.font = (isCenter ? '700 ' : '500 ') + fontSize + 'px sans-serif';
								ctx.textAlign = 'center';
								ctx.textBaseline = 'middle';
								const tw = ctx.measureText(label).width;
								const r = isCenter ? 9 : 6;
								ctx.fillStyle = 'rgba(255,255,255,0.88)';
								ctx.fillRect(node.x - tw/2 - 4, node.y + r + 2, tw + 8, fontSize + 4);
								ctx.fillStyle = isCenter ? '#111' : '#333';
								ctx.fillText(label, node.x, node.y + r + 4 + fontSize * 0.5);
							})
							.nodeLabel((n) => n.title)
							.onNodeClick((n) => { if (n.id !== center) window.location.href = BASE + '/blog/' + n.id + '/'; })
							.cooldownTicks(120);
						setTimeout(() => {
							try {
								fg.d3Force('charge').strength(-380);
								fg.d3Force('link').distance(80);
								fg.d3ReheatSimulation();
							} catch(e) {}
						}, 50);
						fg.onEngineStop(() => fg.zoomToFit(400, 50));
						window.addEventListener('resize', () => fg && fg.width(el.clientWidth));
					}

					if (details && !details.open) {
						details.addEventListener('toggle', () => { if (details.open) init(); }, { once: true });
					} else {
						init();
					}
				</script>
			</>
		)}
	</body>
</html>

<style is:global>
	/* Related v2 — карточки вместо списка ссылок */
	.related-posts .related-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 12px;
	}
	@media (max-width: 720px) {
		.related-posts .related-grid {
			grid-template-columns: 1fr;
		}
	}
	.related-posts .related-card {
		display: flex;
		gap: 12px;
		align-items: flex-start;
		padding: 10px;
		border: 1px solid var(--border);
		border-radius: 6px;
		background: var(--bg-elevated);
		text-decoration: none;
		color: var(--text);
		transition: box-shadow .15s ease, border-color .15s ease;
		min-width: 0;
	}
	.related-posts .related-card:hover {
		box-shadow: 0 4px 14px rgba(0, 0, 0, 0.08);
		border-color: #d4d4d4;
		color: var(--text);
	}
	.related-posts .related-card .thumb {
		flex: 0 0 70px;
		width: 70px;
		height: 70px;
		border-radius: 6px;
		background-color: var(--border-soft);
		background-size: cover;
		background-position: center;
		background-repeat: no-repeat;
		display: block;
	}
	.related-posts .related-card .thumb-fallback {
		display: flex;
		align-items: center;
		justify-content: center;
		font-family: var(--font-heading), 'Play', sans-serif;
		font-size: 1.75rem;
		font-weight: 700;
		color: var(--muted);
		background: linear-gradient(135deg, var(--border-soft) 0%, #ececec 100%);
	}
	.related-posts .related-card .body {
		display: flex;
		flex-direction: column;
		gap: 6px;
		min-width: 0;
		flex: 1 1 auto;
	}
	.related-posts .related-card .ttl {
		font-family: var(--font-heading), 'Play', 'Open Sans', sans-serif;
		font-size: 0.95rem;
		line-height: 1.3;
		font-weight: 700;
		color: var(--text-dark);
		transition: color .15s ease;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
	.related-posts .related-card:hover .ttl {
		color: var(--link);
	}
	.related-posts .related-card .sub {
		font-family: var(--font-ui), system-ui, sans-serif;
		font-size: 0.8125rem;
		line-height: 1.35;
		color: var(--muted);
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
	.related-posts .related-card .meta {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 8px;
		margin-top: 2px;
		font-family: var(--font-ui), system-ui, sans-serif;
		font-size: 0.72rem;
		color: var(--muted-2);
	}
	.related-posts .related-card .meta .d {
		color: var(--muted-2);
	}
	.related-posts .related-card .tag-pills {
		display: inline-flex;
		flex-wrap: wrap;
		gap: 4px;
	}
	.related-posts .related-card .pill {
		display: inline-block;
		padding: 1px 7px;
		border-radius: 999px;
		background: var(--border-soft);
		color: var(--muted);
		font-size: 0.7rem;
		line-height: 1.5;
		border: 1px solid var(--border);
	}
</style>
