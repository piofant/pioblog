---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Neighbor = { id: string; title: string; pubDate: Date } | null;
type Props = CollectionEntry<'blog'>['data'] & {
	prev?: Neighbor;
	next?: Neighbor;
	related?: { id: string; title: string; pubDate: Date }[];
};

const { title, subtitle, pubDate, updatedDate, heroImage, tags, prev, next, related } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!doctype html>
<html lang="ru">
	<head>
		<BaseHead title={title} description={subtitle ?? title} image={heroImage} />
	</head>
	<body>
		<Header />
		<main class="content">
			<article>
				<header class="post-header">
					<div class="post-date">
						<FormattedDate date={pubDate} />
						{updatedDate && <span> · обновлено <FormattedDate date={updatedDate} /></span>}
					</div>
					<h1>{title}</h1>
					{subtitle && <p class="post-subtitle">{subtitle}</p>}
					{tags && tags.length > 0 && (
						<div class="post-tags">
							{tags.map((tag) => (
								<a href={`${base}/tags/${encodeURIComponent(tag)}/`}>{tag}</a>
							))}
						</div>
					)}
				</header>
				<div class="post-content">
					<slot />
				</div>

				{related && related.length > 0 && (
					<aside class="related-posts">
						<h3>Похожие посты</h3>
						<ul>
							{related.map((r) => (
								<li>
									<a href={`${base}/blog/${r.id}/`}>{r.title}</a>
									<span class="d"><FormattedDate date={r.pubDate} short /></span>
								</li>
							))}
						</ul>
					</aside>
				)}

				{(prev || next) && (
					<nav class="post-nav">
						<div class="post-nav-slot prev">
							{prev && (
								<a href={`${base}/blog/${prev.id}/`}>
									<span class="dir">← новее</span>
									<span class="t">{prev.title}</span>
								</a>
							)}
						</div>
						<div class="post-nav-slot next">
							{next && (
								<a href={`${base}/blog/${next.id}/`}>
									<span class="dir">старее →</span>
									<span class="t">{next.title}</span>
								</a>
							)}
						</div>
					</nav>
				)}
			</article>
		</main>
		<Footer />
	</body>
</html>
