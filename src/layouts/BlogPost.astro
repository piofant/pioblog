---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, subtitle, pubDate, updatedDate, heroImage, tags } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!doctype html>
<html lang="ru">
	<head>
		<BaseHead title={title} description={subtitle ?? title} image={heroImage} />
	</head>
	<body>
		<Header />
		<main class="content">
			<article>
				<header class="post-header">
					<div class="post-date">
						<FormattedDate date={pubDate} />
						{updatedDate && <span> · обновлено <FormattedDate date={updatedDate} /></span>}
					</div>
					<h1>{title}</h1>
					{subtitle && <p class="post-subtitle">{subtitle}</p>}
					{tags && tags.length > 0 && (
						<div class="post-tags">
							{tags.map((tag) => (
								<a href={`${base}/tags/${encodeURIComponent(tag)}/`}>{tag}</a>
							))}
						</div>
					)}
					{heroImage && (
						<div class="post-hero">
							<img src={heroImage} alt="" />
						</div>
					)}
				</header>
				<div class="post-content">
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
