---
import BaseHead from '../components/BaseHead.astro';
import { SITE_TITLE } from '../consts';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!doctype html>
<html lang="ru">
	<head>
		<BaseHead
			title="Личный Кабинет"
			description={`Личный Кабинет — ${SITE_TITLE}`}
			image="/avatar_pio.png"
		/>
		<style>
			* { box-sizing: border-box; }
			html, body { margin: 0; padding: 0; height: 100%; background: #050608; color: #eaeaea; font-family: ui-monospace, 'SF Mono', Monaco, monospace; overflow: hidden; }
			body { overscroll-behavior: none; }

			.scene-stage {
				position: fixed; inset: 0;
				z-index: 0;
				background: #0a0a0a;
			}
			canvas { display: block; }

			.cp-loader {
				position: fixed; inset: 0; z-index: 50;
				background: #050608;
				display: flex; align-items: center; justify-content: center;
				transition: opacity 0.6s ease, visibility 0s linear 0.6s;
			}
			.cp-loader.done { opacity: 0; visibility: hidden; }
			.cp-loader .panel {
				font-family: monospace;
				font-size: 13px;
				color: #00ff90;
				text-shadow: 0 0 8px #00ff90;
				display: flex; flex-direction: column; align-items: flex-start;
				padding: 32px 40px;
				border: 1px solid #00ff90;
				box-shadow: 0 0 12px rgba(0, 255, 144, 0.35);
				background: rgba(0, 0, 0, 0.6);
				min-width: 320px;
			}
			.cp-loader .panel > div { margin-bottom: 14px; }
			.cp-loader .panel > div:last-child { margin-bottom: 0; }
			.cp-loader .bar { font-variant-numeric: tabular-nums; }
			.cursor { display: inline-block; animation: blink 1s step-end infinite; }
			@keyframes blink { 0%, 50% { opacity: 1; } 50.01%, 100% { opacity: 0; } }

			/* Hero overlay (top-left) */
			.cp-hero {
				position: fixed; top: 16px; left: 16px;
				z-index: 10;
				font-family: monospace;
				font-size: 12px;
				color: #aef;
				background: rgba(0, 0, 0, 0.55);
				border: 1px solid rgba(0, 255, 144, 0.35);
				border-radius: 4px;
				padding: 10px 14px;
				max-width: 360px;
				backdrop-filter: blur(4px);
			}
			.cp-hero h1 {
				margin: 0 0 6px;
				color: #fff;
				font-size: 14px;
				font-weight: 700;
				letter-spacing: 0.05em;
				text-transform: uppercase;
				font-family: inherit;
			}
			.cp-hero p { margin: 4px 0; line-height: 1.4; }
			.cp-hero a { color: #00ff90; text-decoration: none; border-bottom: 1px dashed transparent; }
			.cp-hero a:hover { border-bottom-color: #00ff90; }
			.cp-hero .specs {
				margin-top: 6px;
				color: #6f8;
				font-size: 11px;
				opacity: 0.85;
			}
			.hero-play {
				display: inline-block;
				margin: 8px 0 4px;
				background: rgba(0, 255, 144, 0.12);
				border: 1px solid #00ff90;
				color: #00ff90;
				font: inherit; font-size: 12px;
				padding: 5px 14px;
				border-radius: 999px;
				cursor: pointer;
				transition: background 0.15s, color 0.15s, transform 0.15s;
			}
			.hero-play:hover { background: #00ff90; color: #000; }
			.hero-play:active { transform: scale(0.97); }

			/* Audio control (bottom-right, маленький pill) */
			.cp-audio {
				position: fixed; bottom: 18px; right: 18px;
				z-index: 10;
				font-family: monospace;
				font-size: 12px;
				display: inline-flex; gap: 10px; align-items: center;
				background: rgba(0, 0, 0, 0.6);
				border: 1px solid rgba(0, 255, 144, 0.35);
				border-radius: 999px;
				padding: 8px 14px;
				backdrop-filter: blur(4px);
				color: #00ff90;
			}
			.cp-audio button {
				background: transparent; border: 0;
				font: inherit; color: inherit;
				cursor: pointer; padding: 0;
			}
			.cp-audio button:hover { color: #fff; text-shadow: 0 0 8px #00ff90; }
			.cp-audio .track { color: #aef; }

			/* Back link (bottom-left) */
			.cp-back {
				position: fixed; bottom: 18px; left: 18px;
				z-index: 10;
				font-family: monospace;
				font-size: 11px;
				color: #6f8;
				text-decoration: none;
				border: 1px solid rgba(0, 255, 144, 0.35);
				border-radius: 4px;
				padding: 6px 10px;
				background: rgba(0, 0, 0, 0.55);
			}
			.cp-back:hover { color: #fff; border-color: #00ff90; }

			.cp-error {
				position: fixed; inset: 0; z-index: 60;
				display: none; align-items: center; justify-content: center;
				background: rgba(0, 0, 0, 0.85);
				color: #ff5566;
				font-family: monospace;
				font-size: 14px;
				text-align: center;
				padding: 32px;
			}
			.cp-error.show { display: flex; }

			@media (max-width: 640px) {
				/* На мобиле прячем хедер целиком — оставляем ТОЛЬКО play кнопку
				   как floating сверху-справа. И back-link внизу-слева. */
				.cp-hero {
					top: 12px; right: 12px;
					left: auto;
					max-width: none;
					padding: 0;
					background: none;
					border: none;
					backdrop-filter: none;
				}
				.cp-hero h1,
				.cp-hero p,
				.cp-hero .specs { display: none; }
				.hero-play {
					margin: 0;
					font-size: 12px;
					padding: 8px 18px;
					background: rgba(0, 0, 0, 0.55);
					backdrop-filter: blur(4px);
				}
				/* Нижнюю play-кнопку прячем — на мобиле управляем сверху */
				.cp-audio { display: none; }
				.cp-back { bottom: 12px; left: 12px; font-size: 11px; padding: 6px 10px; }
				.cp-loader .panel { min-width: 240px; padding: 20px 22px; font-size: 12px; }
			}
		</style>
	</head>
	<body>
		<div class="cp-loader" id="cp-loader">
			<div class="panel">
				<div>&gt; LOADING SCENE...</div>
				<div class="bar">[<span id="cp-bar">░░░░░░░░░░░░░░░░░░░░</span>] <span id="cp-pct">0</span>%<span class="cursor">_</span></div>
				<div id="cp-stage">&gt; init...</div>
			</div>
		</div>

		<div class="scene-stage" id="cp-stage-root"></div>

		<header class="cp-hero">
			<h1>&gt; Vova Lutsenko · v1</h1>
			<p><a href={`${base}/`}>← кабинет</a></p>
			<button class="hero-play" id="cp-play-hero" aria-label="play / pause">▶ play</button>
		</header>

		<div class="cp-audio" id="cp-audio">
			<button id="cp-play" aria-label="play / pause">▶ play</button>
		</div>

		<a class="cp-back" href={`${base}/`}>← кабинет</a>

		<div class="cp-error" id="cp-error">
			<div>
				<div>&gt; ERROR: failed to load avatar.glb</div>
				<div style="margin-top:12px;font-size:11px;opacity:0.7">проверь /3d/avatar.glb и refresh</div>
			</div>
		</div>

		<audio id="cp-audio-el" loop preload="auto"></audio>

		<script type="importmap" is:inline>
			{
				"imports": {
					"three": "https://unpkg.com/three@0.165.0/build/three.module.js",
					"three/addons/": "https://unpkg.com/three@0.165.0/examples/jsm/"
				}
			}
		</script>

		<script type="module" is:inline>
			import * as THREE from 'three';
			import { GLTFLoader } from 'three/addons/loaders/GLTFLoader.js';
			import { OrbitControls } from 'three/addons/controls/OrbitControls.js';
			import { RoomEnvironment } from 'three/addons/environments/RoomEnvironment.js';

			const loader = document.getElementById('cp-loader');
			const bar = document.getElementById('cp-bar');
			const pct = document.getElementById('cp-pct');
			const stageMsg = document.getElementById('cp-stage');
			const errorEl = document.getElementById('cp-error');
			const audioCtl = document.getElementById('cp-audio');
			const playBtn = document.getElementById('cp-play');
			const trackEl = document.getElementById('cp-track');
			const audioEl = document.getElementById('cp-audio-el');

			function setProgress(p, msg) {
				p = Math.max(0, Math.min(100, p));
				const filled = Math.round((p / 100) * 20);
				bar.textContent = '█'.repeat(filled) + '░'.repeat(20 - filled);
				pct.textContent = String(Math.round(p));
				if (msg) stageMsg.textContent = '> ' + msg;
			}

			const stageRoot = document.getElementById('cp-stage-root');
			const scene = new THREE.Scene();
			scene.background = new THREE.Color(0x0a0a0a);

			// Mobile-aware antialias, pixelRatio И камера: на узких экранах
			// чуть отодвигаем камеру (4.4 vs 3.5) — иначе аватар обрезается
			// бутом в 50% экрана из-за вертикального аспекта.
			const isMobile = window.innerWidth < 640 || /Android|iPhone|iPad/i.test(navigator.userAgent);
			const cameraZ = isMobile ? 4.4 : 3.5;

			// Camera: те же FOV/высота что у автора mein3d, Z варьируем по платформе
			const camera = new THREE.PerspectiveCamera(45, window.innerWidth / window.innerHeight, 0.1, 100);
			camera.position.set(0, 1.5, cameraZ);

			const renderer = new THREE.WebGLRenderer({ antialias: !isMobile, alpha: true });
			renderer.setPixelRatio(Math.min(window.devicePixelRatio, isMobile ? 1.5 : 2));
			renderer.setSize(window.innerWidth, window.innerHeight);
			renderer.outputColorSpace = THREE.SRGBColorSpace;
			renderer.toneMapping = THREE.ACESFilmicToneMapping;
			renderer.toneMappingExposure = 1.0;
			stageRoot.appendChild(renderer.domElement);

			// Environment: эквивалент <Environment preset="city" /> из drei у
			// автора mein3d. RoomEnvironment — встроенный procedural HDRI без
			// внешних загрузок, даёт PBR-материалам красивый ambient/reflection.
			const pmrem = new THREE.PMREMGenerator(renderer);
			scene.environment = pmrem.fromScene(new RoomEnvironment(), 0.04).texture;

			// Свет — точно по схеме автора:
			// 1) AmbientLight 0.4 — убирает «чёрные провалы» в тенях
			const ambient = new THREE.AmbientLight(0xffffff, 0.4);
			scene.add(ambient);
			// 2) Key — основной софтбокс спереди-сверху
			const key = new THREE.DirectionalLight(0xffffff, 1.2);
			key.position.set(2, 4, 3);
			scene.add(key);
			// 3) Холодный contre-jour сзади-слева — даёт объём
			const fillCool = new THREE.DirectionalLight(0x8899ff, 0.4);
			fillCool.position.set(-2, 2, -2);
			scene.add(fillCool);
			// Cyber rim сзади — атмосфера
			const rim1 = new THREE.PointLight(0x00ff90, 1.8, 10);
			rim1.position.set(-1.8, 1.6, -1.4);
			scene.add(rim1);
			const rim2 = new THREE.PointLight(0xff3380, 1.2, 10);
			rim2.position.set(1.8, 1.0, -1.6);
			scene.add(rim2);

			// Sci-fi ground — простая сетка
			const grid = new THREE.GridHelper(10, 20, 0x00ff90, 0x222629);
			grid.position.y = 0;
			grid.material.opacity = 0.35;
			grid.material.transparent = true;
			scene.add(grid);

			const controls = new OrbitControls(camera, renderer.domElement);
			controls.enablePan = false;
			controls.minDistance = 1.4;
			controls.maxDistance = 6;
			controls.minPolarAngle = Math.PI * 0.15;
			controls.maxPolarAngle = Math.PI * 0.6;
			controls.target.set(0, 1.0, 0);
			controls.enableDamping = true;
			controls.dampingFactor = 0.06;
			controls.autoRotate = true;
			controls.autoRotateSpeed = 0.6;

			// Два mixer'а — для wait-стейта и для dance. Переключаем visibility
			// при play/pause (вместо паузы анимации).
			let waitAvatar = null, danceAvatar = null;
			let waitMixer = null, danceMixer = null;
			let waitAction = null, danceAction = null;
			const clock = new THREE.Clock();

			function placeAtFloor(obj) {
				const box = new THREE.Box3().setFromObject(obj);
				const center = box.getCenter(new THREE.Vector3());
				obj.position.x -= center.x;
				obj.position.z -= center.z;
				obj.position.y -= box.min.y;
			}
			function loadGLB(url) {
				return new Promise((resolve, reject) => {
					new GLTFLoader().load(url, resolve, undefined, reject);
				});
			}

			(async () => {
				try {
					setProgress(10, 'loading wait pose...');
					const waitGltf = await loadGLB('/3d/avatar-wait.glb');
					waitAvatar = waitGltf.scene;
					placeAtFloor(waitAvatar);
					scene.add(waitAvatar);
					if (waitGltf.animations?.length) {
						waitMixer = new THREE.AnimationMixer(waitAvatar);
						waitAction = waitMixer.clipAction(waitGltf.animations[0]);
						waitAction.play();
					}

					setProgress(50, 'loading dance...');
					const danceGltf = await loadGLB('/3d/avatar.glb');
					danceAvatar = danceGltf.scene;
					placeAtFloor(danceAvatar);
					danceAvatar.visible = false; // скрыт до play
					scene.add(danceAvatar);
					if (danceGltf.animations?.length) {
						danceMixer = new THREE.AnimationMixer(danceAvatar);
						danceAction = danceMixer.clipAction(danceGltf.animations[0]);
						danceAction.play();
						danceAction.paused = true;
					}

					setProgress(100, 'ready');
					setTimeout(() => loader.classList.add('done'), 250);
				} catch (e) {
					console.error('load/parse error', e);
					stageMsg.textContent = '> ERROR: ' + (e?.message || 'load failed');
					errorEl.classList.add('show');
				}
			})();

			window.addEventListener('resize', () => {
				camera.aspect = window.innerWidth / window.innerHeight;
				camera.updateProjectionMatrix();
				renderer.setSize(window.innerWidth, window.innerHeight);
			});

			function tick() {
				requestAnimationFrame(tick);
				const dt = clock.getDelta();
				if (waitMixer && waitAvatar?.visible) waitMixer.update(dt);
				if (danceMixer && danceAvatar?.visible) danceMixer.update(dt);
				controls.update();
				renderer.render(scene, camera);
			}
			tick();

			// === Play button — переключает wait-pose ↔ dance + музыку ===
			audioEl.src = '/audio/cyberpunk-shuffle.mp3';
			const playBtnHero = document.getElementById('cp-play-hero');
			let playing = false;
			function setBtnLabel(label) {
				playBtn.textContent = label;
				if (playBtnHero) playBtnHero.textContent = label;
			}
			function toggle() {
				if (playing) {
					// Pause: switch to wait pose, остановить музыку
					if (danceAction) danceAction.paused = true;
					if (danceAvatar) danceAvatar.visible = false;
					if (waitAvatar) waitAvatar.visible = true;
					audioEl.pause();
					setBtnLabel('▶ play');
					controls.autoRotate = true;
				} else {
					// Play: switch to dance pose, запустить музыку
					if (waitAvatar) waitAvatar.visible = false;
					if (danceAvatar) danceAvatar.visible = true;
					if (danceAction) danceAction.paused = false;
					audioEl.play().catch((e) => console.warn('audio play blocked:', e));
					setBtnLabel('❚❚ pause');
					controls.autoRotate = false; // во время танца — не крутим, чтоб движения было видно
				}
				playing = !playing;
			}
			playBtn.addEventListener('click', toggle);
			playBtnHero?.addEventListener('click', toggle);
		</script>
	</body>
</html>
