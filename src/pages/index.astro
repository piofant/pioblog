---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const RECENT_COUNT = 15;
const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, RECENT_COUNT);

function excerptOf(body: string, words = 20): string {
	const text = body
		.replace(/```[\s\S]*?```/g, '')
		.replace(/`[^`]*`/g, '')
		.replace(/!\[[^\]]*\]\([^)]*\)/g, '')
		.replace(/\[([^\]]*)\]\([^)]*\)/g, '$1')
		.replace(/\*\*|\*|__|_/g, '')
		.replace(/#+\s+/g, '')
		.replace(/>\s*/g, '')
		.replace(/\s+/g, ' ')
		.trim();
	const parts = text.split(/\s+/);
	return parts.slice(0, words).join(' ') + (parts.length > words ? '…' : '');
}
---

<!doctype html>
<html lang="ru">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="feed">
			<ul class="posts-list">
				{posts.map((post) => (
					<li class="post-card">
						<p class="card-date"><FormattedDate date={post.data.pubDate} short /></p>
						<a class="card-link" href={`${base}/blog/${post.id}/`}>{post.data.title}</a>
						{post.data.subtitle && <p class="card-sub">{post.data.subtitle}</p>}
						{!post.data.subtitle && post.body && (
							<p class="card-excerpt">{excerptOf(post.body)}</p>
						)}
						{post.data.heroImage && (
							<a class="card-image" href={`${base}/blog/${post.id}/`} aria-label={post.data.title}>
								<img src={post.data.heroImage} alt="" />
							</a>
						)}
					</li>
				))}
			</ul>

			<p class="all-posts-link">
				<a href={`${base}/archive/`}>Все посты &rarr;</a>
			</p>
		</main>
		<Footer />
	</body>
</html>
