---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

export async function getStaticPaths() {
	const META_TAGS = new Set(['whois', 'intro', 'история', 'истории', 'жизнипост', 'мысли', 'telegram']);
	const primaryTagOf = (tags?: string[]): string =>
		(tags || []).find((t) => !META_TAGS.has(t)) || 'разное';

	const allPosts = await getCollection('blog');
	const tags = new Set<string>();
	for (const p of allPosts) {
		for (const t of p.data.tags ?? []) tags.add(t);
	}

	// Build adjacency for ALL posts once (links + tag co-occurrence)
	const slugSet = new Set(allPosts.map((p) => p.id));
	const adj = new Map<string, Set<string>>();
	for (const p of allPosts) adj.set(p.id, new Set());
	const LINK_RE = /\]\(\/blog\/([a-z0-9-]+)\/?\)/g;
	for (const p of allPosts) {
		const body = p.body || '';
		for (const m of body.matchAll(LINK_RE)) {
			const target = m[1];
			if (slugSet.has(target) && target !== p.id) {
				adj.get(p.id)!.add(target);
				adj.get(target)!.add(p.id);
			}
		}
	}
	const byTag = new Map<string, string[]>();
	for (const p of allPosts) for (const t of p.data.tags ?? []) {
		if (!byTag.has(t)) byTag.set(t, []);
		byTag.get(t)!.push(p.id);
	}
	for (const [, ids] of byTag) {
		if (ids.length <= 1) continue;
		ids.sort();
		for (let i = 0; i < ids.length - 1; i++) {
			adj.get(ids[i])!.add(ids[i + 1]);
			adj.get(ids[i + 1])!.add(ids[i]);
		}
	}

	// «whois»-пост который определяет концепт «трипы» — пиним первым на любой
	// странице тега, где он размечен этим тегом
	const PINNED_FIRST_SLUG = 'chto-takoe-tripy-v-diskaveri-novogo-opyta-184';

	return [...tags].map((tag) => {
		const filtered = allPosts
			.filter((p) => (p.data.tags ?? []).includes(tag))
			.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
		// Закреп: если pinned-пост есть в этом теге — поднять его наверх
		const pinned = filtered.find((p) => p.id === PINNED_FIRST_SLUG);
		const taggedPosts = pinned
			? [pinned, ...filtered.filter((p) => p.id !== PINNED_FIRST_SLUG)]
			: filtered;
		const taggedIds = new Set(taggedPosts.map((p) => p.id));
		const subNodes = taggedPosts.map((p) => ({
			id: p.id,
			title: p.data.title,
			subtitle: p.data.subtitle ?? '',
			heroImage: p.data.heroImage ?? '',
			date: p.data.pubDate.toISOString().slice(0, 10),
			primaryTag: primaryTagOf(p.data.tags),
		}));
		const subEdges: { source: string; target: string }[] = [];
		const seen = new Set<string>();
		for (const id of taggedIds) {
			for (const nb of adj.get(id) || []) {
				if (taggedIds.has(nb)) {
					const k = [id, nb].sort().join('|');
					if (seen.has(k)) continue;
					seen.add(k);
					subEdges.push({ source: id, target: nb });
				}
			}
		}
		return {
			params: { tag },
			props: { tag, posts: taggedPosts, subgraph: { nodes: subNodes, links: subEdges } },
		};
	});
}

const { tag, posts, subgraph } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const showSubgraph = subgraph.nodes.length >= 3;

function excerptOf(body: string, words = 20): string {
	const text = body
		.replace(/```[\s\S]*?```/g, '')
		.replace(/`[^`]*`/g, '')
		.replace(/!\[[^\]]*\]\([^)]*\)/g, '')
		.replace(/\[([^\]]*)\]\([^)]*\)/g, '$1')
		.replace(/\*\*|\*|__|_/g, '')
		.replace(/#+\s+/g, '')
		.replace(/>\s*/g, '')
		.replace(/\s+/g, ' ')
		.trim();
	const parts = text.split(/\s+/);
	return parts.slice(0, words).join(' ') + (parts.length > words ? '…' : '');
}
---

<!doctype html>
<html lang="ru">
	<head>
		<BaseHead title={`#${tag}`} description={`Посты по тегу ${tag} — ${SITE_TITLE}`} />
	</head>
	<body>
		<Header />
		<main class="content archive-page">
			<h1>#{tag}</h1>
			<p style="color: var(--muted); margin: 0 0 1.5rem;">{posts.length} постов</p>

			{showSubgraph && (
				<div class="mini-graph-wrap" style="margin-top: 0; padding-top: 0; border-top: 0; position: relative;">
					<div class="mini-graph" id="tag-graph" style="height: 380px;"></div>
					<div class="node-popup" id="node-popup" hidden>
						<button type="button" class="popup-close" id="popup-close" aria-label="Закрыть">×</button>
						<div class="popup-inner">
							<div class="popup-thumb" id="popup-thumb"></div>
							<div class="popup-body">
								<div class="popup-date" id="popup-date"></div>
								<div class="popup-title" id="popup-title"></div>
								<div class="popup-sub" id="popup-sub"></div>
								<a class="popup-cta" id="popup-cta" href="#">Открыть пост →</a>
							</div>
						</div>
					</div>
				</div>
			)}

			<style>
				.node-popup {
					position: absolute;
					background: var(--bg-elevated);
					border: 1px solid var(--border);
					border-radius: 8px;
					box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
					max-width: 320px;
					padding: 12px 14px;
					z-index: 50;
					font-family: var(--font-ui), system-ui, sans-serif;
				}
				.node-popup[hidden] { display: none; }
				.popup-close {
					position: absolute;
					top: 4px;
					right: 8px;
					background: none;
					border: 0;
					font-size: 18px;
					line-height: 1;
					cursor: pointer;
					color: var(--muted-2);
					padding: 4px 6px;
				}
				.popup-close:hover { color: var(--text-dark); }
				.popup-inner { display: flex; gap: 10px; align-items: flex-start; }
				.popup-thumb {
					flex: 0 0 64px;
					width: 64px;
					height: 64px;
					border-radius: 6px;
					background: var(--border-soft);
					background-size: cover;
					background-position: center;
				}
				.popup-thumb.empty { display: none; }
				.popup-body { flex: 1; min-width: 0; }
				.popup-date {
					font-size: 11px;
					color: var(--muted-2);
					text-transform: uppercase;
					letter-spacing: 0.05em;
					margin-bottom: 2px;
				}
				.popup-title {
					font-family: var(--font-heading), sans-serif;
					font-weight: 700;
					font-size: 0.95rem;
					line-height: 1.3;
					color: var(--text-dark);
					margin-bottom: 4px;
				}
				.popup-sub {
					font-size: 0.8125rem;
					color: var(--muted);
					line-height: 1.4;
					margin-bottom: 8px;
				}
				.popup-sub:empty { display: none; }
				.popup-cta {
					display: inline-block;
					font-size: 0.8125rem;
					font-weight: 600;
					color: var(--link);
					text-decoration: none;
				}
				.popup-cta:hover { color: var(--link-hover); }
			</style>

			<ul class="posts-list" style="margin-top: 1.5rem;">
				{posts.map((post) => (
					<li class="post-card">
						<p class="card-date"><FormattedDate date={post.data.pubDate} short /></p>
						<a class="card-link" href={`${base}/blog/${post.id}/`}>{post.data.title}</a>
						{post.data.subtitle && <p class="card-sub">{post.data.subtitle}</p>}
						{!post.data.subtitle && post.body && (
							<p class="card-excerpt">{excerptOf(post.body)}</p>
						)}
						{post.data.heroImage && (
							<a class="card-image" href={`${base}/blog/${post.id}/`} aria-label={post.data.title}>
								<img src={post.data.heroImage} alt="" />
							</a>
						)}
					</li>
				))}
			</ul>
		</main>
		<Footer />

		{showSubgraph && (
			<>
				<script src="https://cdn.jsdelivr.net/npm/force-graph@1.49.5/dist/force-graph.min.js" is:inline></script>
				<script define:vars={{ DATA: subgraph, BASE: base }} is:inline>
					const palette = {
						'продакт':'#ff4200','карьера':'#e11d48','школа жизни':'#f59e0b',
						'вуз':'#1e40af','трипы':'#10b981','рефлексия':'#8b5cf6',
						'психология':'#a855f7','нетворкинг':'#06b6d4','безумие':'#ec4899',
						'театр':'#f43f5e','ии':'#0ea5e9','анонс':'#14b8a6','боты':'#22c55e',
						'танцы':'#d946ef','творчество':'#eab308','жизнь':'#84cc16',
						'друзья':'#f97316','мнения':'#64748b',
					};
					const el = document.getElementById('tag-graph');
					const popup = document.getElementById('node-popup');
					const popupClose = document.getElementById('popup-close');
					const popupThumb = document.getElementById('popup-thumb');
					const popupDate = document.getElementById('popup-date');
					const popupTitle = document.getElementById('popup-title');
					const popupSub = document.getElementById('popup-sub');
					const popupCta = document.getElementById('popup-cta');

					function showNodePopup(node) {
						const containerRect = el.getBoundingClientRect();
						// node.x/y — координаты внутри canvas, нужно перевести в DOM-пиксели
						const screen = fg.graph2ScreenCoords(node.x, node.y);
						let left = screen.x + 12;
						let top = screen.y - 30;
						// держим popup в пределах контейнера
						const maxLeft = containerRect.width - 340;
						if (left > maxLeft) left = maxLeft;
						if (left < 8) left = 8;
						if (top < 8) top = 8;
						popup.style.left = left + 'px';
						popup.style.top = top + 'px';
						if (node.heroImage) {
							popupThumb.style.backgroundImage = "url('" + node.heroImage + "')";
							popupThumb.classList.remove('empty');
						} else {
							popupThumb.classList.add('empty');
						}
						const dt = new Date(node.date);
						popupDate.textContent = dt.toLocaleDateString('ru-RU', { day: 'numeric', month: 'short', year: 'numeric' });
						popupTitle.textContent = node.title;
						popupSub.textContent = node.subtitle || '';
						popupCta.href = BASE + '/blog/' + node.id + '/';
						popup.hidden = false;
					}
					function hidePopup() { popup.hidden = true; }
					popupClose.addEventListener('click', hidePopup);
					document.addEventListener('click', (e) => {
						if (!popup.contains(e.target) && e.target.tagName !== 'CANVAS') hidePopup();
					});
					document.addEventListener('keydown', (e) => { if (e.key === 'Escape') hidePopup(); });

					// degree
					const deg = new Map();
					DATA.nodes.forEach(n => deg.set(n.id, 0));
					DATA.links.forEach(l => {
						deg.set(l.source, (deg.get(l.source) || 0) + 1);
						deg.set(l.target, (deg.get(l.target) || 0) + 1);
					});
					DATA.nodes.forEach(n => { n.deg = deg.get(n.id) || 0; });

					const getCss = (name) => getComputedStyle(document.documentElement).getPropertyValue(name).trim();
					let highlighted = null;
					const fg = ForceGraph()(el)
						.graphData({ nodes: DATA.nodes.map(n => ({...n})), links: DATA.links.map(l => ({...l})) })
						.backgroundColor('rgba(0,0,0,0)')
						.width(el.clientWidth)
						.height(380)
						.nodeRelSize(5)
						.nodeVal(n => 1 + Math.min(n.deg, 10) * 0.6)
						.nodeColor(n => palette[n.primaryTag] || getCss('--muted'))
						.linkColor(() => getCss('--graph-link'))
						.linkWidth(1)
						.nodeCanvasObjectMode(() => 'after')
						.nodeCanvasObject((node, ctx, scale) => {
							const label = node.title.slice(0, 32);
							const isHighlighted = node.id === highlighted;
							const fontSize = Math.max(9, (isHighlighted ? 11 : 9) / Math.max(scale, 0.7));
							ctx.font = (isHighlighted ? '600 ' : '500 ') + fontSize + 'px sans-serif';
							ctx.textAlign = 'center';
							ctx.textBaseline = 'middle';
							const r = 5 * Math.sqrt(1 + Math.min(node.deg, 10) * 0.6);
							const tw = ctx.measureText(label).width;
							ctx.fillStyle = getCss('--graph-text-bg');
							ctx.fillRect(node.x - tw/2 - 4, node.y + r + 2, tw + 8, fontSize + 4);
							ctx.fillStyle = isHighlighted ? getCss('--text-dark') : getCss('--graph-text');
							ctx.fillText(label, node.x, node.y + r + 4 + fontSize * 0.5);
						})
						.nodeLabel(n => n.title)
						.onNodeHover(n => {
							highlighted = n ? n.id : null;
							fg.nodeCanvasObjectMode(fg.nodeCanvasObjectMode());
						})
						.onNodeClick(n => { showNodePopup(n); })
						.cooldownTicks(250)
						.warmupTicks(100);
					setTimeout(() => {
						try {
							fg.d3Force('charge').strength(-450);
							fg.d3Force('link').distance(80);
							fg.d3ReheatSimulation();
						} catch(e) {}
					}, 50);
					fg.onEngineStop(() => fg.zoomToFit(400, 40));
					window.addEventListener('resize', () => fg.width(el.clientWidth));
					window.addEventListener('themechange', () => fg.refresh());
				</script>
			</>
		)}
	</body>
</html>
