---
/* /go — разводящая страница для шортлинка.
   Две большие плитки → менторство и «чем могу быть полезен». Без шапки про
   вики, без оверхэда — просто два call-to-action для входящих с офлайна. */
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { gradientStyle } from '../lib/gradient';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const tiles = [
	{
		id: 'mentoring',
		title: 'Менторство по продакт-менеджменту в IT',
		subtitle: 'разовая консультация / регулярное сопровождение по карьерным и рабочим вопросам',
	},
	{
		id: 'about',
		title: 'Чем могу быть полезен',
		subtitle: 'консультации, спикинг, коллабы — что у меня есть и чем умею',
	},
];
---

<!doctype html>
<html lang="ru">
	<head>
		<BaseHead title="го" description="разводяющая — менторство, консультации, коллабы" />
	</head>
	<body>
		<Header />
		<main class="content go-page">
			<h1 class="go-title">привет 👋</h1>
			<p class="go-sub">сюда и сюда:</p>
			<div class="go-grid">
				{tiles.map((t) => (
					<a class="go-card" href={`${base}/wiki/${t.id}/`}>
						<span class="thumb" aria-hidden="true" style={gradientStyle(t.id)}></span>
						<span class="body">
							<span class="ttl">{t.title}</span>
							<span class="sub">{t.subtitle}</span>
						</span>
					</a>
				))}
			</div>
		</main>
		<Footer />

		<style>
			.go-page { max-width: 720px; }
			.go-title {
				text-align: center;
				font-family: var(--font-hero), 'Forum', Georgia, serif;
				font-size: 2.5rem;
				margin: 1.5rem 0 0.25rem;
			}
			.go-sub {
				text-align: center;
				color: var(--muted);
				font-family: var(--font-ui), system-ui, sans-serif;
				margin: 0 0 2rem;
				font-size: 1rem;
			}
			.go-grid {
				display: grid;
				grid-template-columns: repeat(2, minmax(0, 1fr));
				gap: 16px;
			}
			@media (max-width: 720px) {
				.go-grid { grid-template-columns: 1fr; }
			}
			.go-card {
				display: flex;
				gap: 16px;
				align-items: flex-start;
				padding: 16px;
				border: 1px solid var(--border);
				border-radius: 8px;
				background: var(--bg-elevated);
				text-decoration: none;
				color: var(--text);
				transition: box-shadow .15s ease, border-color .15s ease, transform .15s ease;
				min-width: 0;
			}
			.go-card:hover {
				box-shadow: 0 6px 18px var(--shadow-sm);
				border-color: var(--text);
				color: var(--text);
				transform: translateY(-2px);
			}
			.go-card .thumb {
				flex: 0 0 96px;
				width: 96px;
				height: 96px;
				border-radius: 8px;
				background-color: var(--border-soft);
				background-size: cover;
				background-position: center;
				background-repeat: no-repeat;
			}
			.go-card .body { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 6px; }
			.go-card .ttl {
				font-family: var(--font-ui), system-ui, sans-serif;
				font-weight: 600;
				font-size: 1.0625rem;
				color: var(--text-dark);
				line-height: 1.3;
			}
			.go-card .sub {
				font-family: var(--font-ui), system-ui, sans-serif;
				font-size: 0.875rem;
				color: var(--muted);
				line-height: 1.4;
			}
		</style>
	</body>
</html>
