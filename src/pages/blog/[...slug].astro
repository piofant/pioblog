---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import { getPublishedPosts } from '../../lib/blog';
import BlogPost from '../../layouts/BlogPost.astro';
import { SERIES } from '../../series';
import { excerptOf } from '../../lib/excerpt';

export async function getStaticPaths() {
	// Мета-теги: типы постов / зонтики, не тематические — не используем для related/color
	const META_TAGS = new Set([
		'whois', 'telegram', 'анонс',         // тип поста
		'жизнь', 'школа жизни',                // umbrella-теги (40+ постов каждый — слишком общие)
		'истории',                             // мета-формат (story-style)
		'рекомендации',                        // тип поста
	]);
	const primaryTagOf = (tags?: string[]): string =>
		(tags || []).find((t) => !META_TAGS.has(t)) || 'разное';

	const posts = (await getPublishedPosts())
		.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

	// IDF-веса тегов: узкий тег (мужские круги, випассана) весит больше, чем широкий
	const tagFrequency = new Map<string, number>();
	for (const p of posts) for (const t of p.data.tags ?? []) {
		tagFrequency.set(t, (tagFrequency.get(t) || 0) + 1);
	}
	const tagWeight = (tag: string): number => {
		if (META_TAGS.has(tag)) return 0;
		const freq = tagFrequency.get(tag) || 1;
		// log-scaled IDF: 2 поста → ~3.4, 10 → 2.4, 40 → 1.2, 100 → 0.5
		return Math.log(posts.length / freq);
	};

	// Build adjacency: edges from internal links + tag co-occurrence (chain)
	const slugSet = new Set(posts.map((p) => p.id));
	const adj = new Map<string, Set<string>>();
	for (const p of posts) adj.set(p.id, new Set());

	const LINK_RE = /\]\(\/blog\/([a-z0-9-]+)\/?\)/g;
	for (const p of posts) {
		const body = p.body || '';
		for (const m of body.matchAll(LINK_RE)) {
			const target = m[1];
			if (slugSet.has(target) && target !== p.id) {
				adj.get(p.id)!.add(target);
				adj.get(target)!.add(p.id);
			}
		}
	}
	const byTag = new Map<string, string[]>();
	for (const p of posts) for (const t of p.data.tags ?? []) {
		if (!byTag.has(t)) byTag.set(t, []);
		byTag.get(t)!.push(p.id);
	}
	// Tag co-occurrence:
	// - Узкие теги (≤8 постов): полная связность всех постов в группе
	// - Средние (9-20): соседи в отсортированном по pubDate списке (chain)
	// - Широкие META-теги (жизнь, школа жизни и т.п.): пропускаем, шум
	for (const [tag, ids] of byTag) {
		if (ids.length <= 1) continue;
		if (META_TAGS.has(tag)) continue;
		if (ids.length <= 8) {
			// full mesh для узкого тега
			for (let i = 0; i < ids.length; i++) {
				for (let j = i + 1; j < ids.length; j++) {
					adj.get(ids[i])!.add(ids[j]);
					adj.get(ids[j])!.add(ids[i]);
				}
			}
		} else {
			// chain для среднего тега (по дате, чтобы соседи были близкие по времени)
			const sorted = [...ids].sort((a, b) => {
				const ad = posts.find((p) => p.id === a)?.data.pubDate.valueOf() || 0;
				const bd = posts.find((p) => p.id === b)?.data.pubDate.valueOf() || 0;
				return ad - bd;
			});
			for (let i = 0; i < sorted.length - 1; i++) {
				adj.get(sorted[i])!.add(sorted[i + 1]);
				adj.get(sorted[i + 1])!.add(sorted[i]);
			}
		}
	}
	const titleById = new Map(posts.map((p) => [p.id, p.data.title]));
	const tagById = new Map(posts.map((p) => [p.id, primaryTagOf(p.data.tags)]));
	const dateById = new Map(posts.map((p) => [p.id, p.data.pubDate]));

	// Group posts by series (slug → ordered parts)
	const bySeries = new Map<string, typeof posts>();
	for (const p of posts) {
		const s = p.data.series;
		if (!s) continue;
		if (!bySeries.has(s)) bySeries.set(s, []);
		bySeries.get(s)!.push(p);
	}
	for (const [, list] of bySeries) {
		list.sort((a, b) => (a.data.seriesPart ?? 0) - (b.data.seriesPart ?? 0));
	}

	return posts.map((post, i) => {
		const prev = posts[i - 1] || null;
		const next = posts[i + 1] || null;

		// Series info
		const seriesSlug = post.data.series;
		const seriesEntry = seriesSlug ? SERIES[seriesSlug] : null;
		const seriesParts = seriesSlug ? (bySeries.get(seriesSlug) || []) : [];
		const seriesNodes = seriesParts.map((p) => ({
			id: p.id,
			title: p.data.title,
			part: p.data.seriesPart ?? 0,
		}));
		const myPart = post.data.seriesPart ?? 0;
		// next non-current sibling with greater part
		const nextSibling = seriesNodes.find((n) => n.part > myPart) || null;
		const seriesData = seriesEntry && seriesNodes.length > 1
			? {
				slug: seriesSlug!,
				name: seriesEntry.name,
				introSlug: seriesEntry.introSlug ?? null,
				parts: seriesNodes,
				currentPart: myPart,
				nextSibling,
			}
			: null;

		// Related — series mates first, then IDF-weighted tag-overlap (cap 4)
		const myTags = new Set(post.data.tags || []);
		const seriesMates = seriesParts
			.filter((p) => p.id !== post.id)
			.map((p) => ({
				id: p.id,
				title: p.data.title,
				heroImage: p.data.heroImage ?? '',
				pubDate: p.data.pubDate,
				sharedTags: [] as string[], // series mates: общая принадлежность к серии, теги не показываем
			}));
		const seenIds = new Set([post.id, ...seriesMates.map((m) => m.id)]);

		// Score = sum of IDF weights of shared tags (META filtered out via tagWeight=0)
		// + small recency bonus to slightly prefer newer posts при равном score
		const myDate = post.data.pubDate.valueOf();
		const tagScored = posts
			.filter((p, j) => j !== i && !seenIds.has(p.id) && p.data.tags && p.data.tags.length)
			.map((p) => {
				const sharedTagsAll = (p.data.tags || []).filter((t) => myTags.has(t));
				// Для UI: только не-META теги (мета-теги визуально шумят и неинформативны)
				const sharedTags = sharedTagsAll.filter((t) => !META_TAGS.has(t));
				const score = sharedTagsAll.reduce((acc, t) => acc + tagWeight(t), 0);
				// Recency: разница в днях, нормализованная (макс +0.3 за свежесть)
				const daysDiff = Math.abs((myDate - p.data.pubDate.valueOf()) / (1000 * 60 * 60 * 24));
				const recencyBonus = Math.max(0, 0.3 - daysDiff / 1000);
				return { post: p, score: score + recencyBonus, sharedTags };
			})
			.filter((x) => x.score > 0)
			.sort((a, b) => b.score - a.score || b.post.data.pubDate.valueOf() - a.post.data.pubDate.valueOf())
			.map((x) => ({
				id: x.post.id,
				title: x.post.data.title,
				heroImage: x.post.data.heroImage ?? '',
				pubDate: x.post.data.pubDate,
				sharedTags: x.sharedTags,
			}));
		const scored = [...seriesMates, ...tagScored].slice(0, 4);

		// Mini-graph: 1-hop neighbors capped at 14 (+ center = 15)
		const neighbors = [...(adj.get(post.id) || [])].slice(0, 14);
		const ids = [post.id, ...neighbors];
		const idSet = new Set(ids);
		const miniNodes = ids.map((id) => ({
			id,
			title: titleById.get(id) || id,
			primaryTag: tagById.get(id) || 'разное',
			date: (dateById.get(id) ?? new Date()).toISOString().slice(0, 10),
		}));
		const miniEdges: { source: string; target: string }[] = [];
		const seen = new Set<string>();
		for (const id of ids) {
			for (const nb of adj.get(id) || []) {
				if (idSet.has(nb)) {
					const k = [id, nb].sort().join('|');
					if (seen.has(k)) continue;
					seen.add(k);
					miniEdges.push({ source: id, target: nb });
				}
			}
		}

		// TG message id извлекаем из суффикса slug'а: '...-384' → 384
		const tgMatch = post.id.match(/-(\d+)$/);
		const tgMessageId = tgMatch ? Number(tgMatch[1]) : null;

		return {
			params: { slug: post.id },
			props: {
				post,
				prev: prev ? { id: prev.id, title: prev.data.title, pubDate: prev.data.pubDate } : null,
				next: next ? { id: next.id, title: next.data.title, pubDate: next.data.pubDate } : null,
				related: scored,
				miniGraph: { nodes: miniNodes, links: miniEdges },
				series: seriesData,
				tgMessageId,
				excerpt: excerptOf(post.body || '', 28),
			},
		};
	});
}

const { post, prev, next, related, miniGraph, series, tgMessageId, excerpt } = Astro.props;
const { Content } = await render(post);
---

<BlogPost {...post.data} prev={prev} next={next} related={related} miniGraph={miniGraph} series={series} tgMessageId={tgMessageId} excerpt={excerpt}>
	<Content />
</BlogPost>
