---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';
import { SERIES } from '../../series';

export async function getStaticPaths() {
	const META_TAGS = new Set(['whois', 'intro', 'история', 'истории', 'жизнипост', 'мысли', 'telegram']);
	const primaryTagOf = (tags?: string[]): string =>
		(tags || []).find((t) => !META_TAGS.has(t)) || 'разное';

	const posts = (await getCollection('blog'))
		.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

	// Build adjacency: edges from internal links + tag co-occurrence (chain)
	const slugSet = new Set(posts.map((p) => p.id));
	const adj = new Map<string, Set<string>>();
	for (const p of posts) adj.set(p.id, new Set());

	const LINK_RE = /\]\(\/blog\/([a-z0-9-]+)\/?\)/g;
	for (const p of posts) {
		const body = p.body || '';
		for (const m of body.matchAll(LINK_RE)) {
			const target = m[1];
			if (slugSet.has(target) && target !== p.id) {
				adj.get(p.id)!.add(target);
				adj.get(target)!.add(p.id);
			}
		}
	}
	const byTag = new Map<string, string[]>();
	for (const p of posts) for (const t of p.data.tags ?? []) {
		if (!byTag.has(t)) byTag.set(t, []);
		byTag.get(t)!.push(p.id);
	}
	for (const [, ids] of byTag) {
		if (ids.length <= 1) continue;
		ids.sort();
		for (let i = 0; i < ids.length - 1; i++) {
			adj.get(ids[i])!.add(ids[i + 1]);
			adj.get(ids[i + 1])!.add(ids[i]);
		}
	}
	const titleById = new Map(posts.map((p) => [p.id, p.data.title]));
	const tagById = new Map(posts.map((p) => [p.id, primaryTagOf(p.data.tags)]));
	const dateById = new Map(posts.map((p) => [p.id, p.data.pubDate]));

	// Group posts by series (slug → ordered parts)
	const bySeries = new Map<string, typeof posts>();
	for (const p of posts) {
		const s = p.data.series;
		if (!s) continue;
		if (!bySeries.has(s)) bySeries.set(s, []);
		bySeries.get(s)!.push(p);
	}
	for (const [, list] of bySeries) {
		list.sort((a, b) => (a.data.seriesPart ?? 0) - (b.data.seriesPart ?? 0));
	}

	return posts.map((post, i) => {
		const prev = posts[i - 1] || null;
		const next = posts[i + 1] || null;

		// Series info
		const seriesSlug = post.data.series;
		const seriesEntry = seriesSlug ? SERIES[seriesSlug] : null;
		const seriesParts = seriesSlug ? (bySeries.get(seriesSlug) || []) : [];
		const seriesNodes = seriesParts.map((p) => ({
			id: p.id,
			title: p.data.title,
			subtitle: p.data.subtitle ?? '',
			part: p.data.seriesPart ?? 0,
		}));
		const myPart = post.data.seriesPart ?? 0;
		// next non-current sibling with greater part
		const nextSibling = seriesNodes.find((n) => n.part > myPart) || null;
		const seriesData = seriesEntry && seriesNodes.length > 1
			? {
				slug: seriesSlug!,
				name: seriesEntry.name,
				introSlug: seriesEntry.introSlug ?? null,
				parts: seriesNodes,
				currentPart: myPart,
				nextSibling,
			}
			: null;

		// Related — series mates first, then tag-overlap fill (cap 4)
		const myTags = new Set(post.data.tags || []);
		const seriesMates = seriesParts
			.filter((p) => p.id !== post.id)
			.map((p) => ({ id: p.id, title: p.data.title, pubDate: p.data.pubDate }));
		const seenIds = new Set([post.id, ...seriesMates.map((m) => m.id)]);
		const tagScored = posts
			.filter((p, j) => j !== i && !seenIds.has(p.id) && p.data.tags && p.data.tags.length)
			.map((p) => ({
				post: p,
				overlap: (p.data.tags || []).filter((t) => myTags.has(t)).length,
			}))
			.filter((x) => x.overlap > 0)
			.sort((a, b) => b.overlap - a.overlap || b.post.data.pubDate.valueOf() - a.post.data.pubDate.valueOf())
			.map((x) => ({ id: x.post.id, title: x.post.data.title, pubDate: x.post.data.pubDate }));
		const scored = [...seriesMates, ...tagScored].slice(0, 4);

		// Mini-graph: 1-hop neighbors capped at 14 (+ center = 15)
		const neighbors = [...(adj.get(post.id) || [])].slice(0, 14);
		const ids = [post.id, ...neighbors];
		const idSet = new Set(ids);
		const miniNodes = ids.map((id) => ({
			id,
			title: titleById.get(id) || id,
			primaryTag: tagById.get(id) || 'разное',
			date: (dateById.get(id) ?? new Date()).toISOString().slice(0, 10),
		}));
		const miniEdges: { source: string; target: string }[] = [];
		const seen = new Set<string>();
		for (const id of ids) {
			for (const nb of adj.get(id) || []) {
				if (idSet.has(nb)) {
					const k = [id, nb].sort().join('|');
					if (seen.has(k)) continue;
					seen.add(k);
					miniEdges.push({ source: id, target: nb });
				}
			}
		}

		return {
			params: { slug: post.id },
			props: {
				post,
				prev: prev ? { id: prev.id, title: prev.data.title, pubDate: prev.data.pubDate } : null,
				next: next ? { id: next.id, title: next.data.title, pubDate: next.data.pubDate } : null,
				related: scored,
				miniGraph: { nodes: miniNodes, links: miniEdges },
				series: seriesData,
			},
		};
	});
}

const { post, prev, next, related, miniGraph, series } = Astro.props;
const { Content } = await render(post);
---

<BlogPost {...post.data} prev={prev} next={next} related={related} miniGraph={miniGraph} series={series}>
	<Content />
</BlogPost>
