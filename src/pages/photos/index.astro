---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const ASSET = (sub: string, file: string) => `${base}/img/photos/proyavlennost/${sub}/${file}`;
const POST = (slug: string) => `${base}/blog/${slug}/`;

type Chapter = {
	slug: string;
	title: string;
	blurb: string;
	photos: string[];
};

const album: { title: string; total: number; chapters: Chapter[] } = {
	title: 'Проявленность и движение',
	total: 21,
	chapters: [
		{
			slug: 'okno',
			title: 'Окно',
			blurb: 'Ночь, синий свет, фигура в белом отрабатывает движение на подоконнике.',
			photos: [
				'okno-1-4068.jpg',
				'okno-2-4085.jpg',
				'okno-3-4094.jpg',
				'okno-4-4119.jpg',
				'okno-5-4141.jpg',
				'okno-6-4142.jpg',
			],
		},
		{
			slug: 'ulitsa',
			title: 'Улица',
			blurb: `Город как площадка для тела — отголоски <a href="${POST('moi-put-k-kontaktnoi-improvizatsii-380')}">контактной импровизации</a> · мой <a href="${POST('u-menia-est-liubimyi-stolb-v-tsentre-pitera-363')}">любимый столб</a>.`,
			photos: [
				'ulitsa-1-fall-up.jpg',
				'ulitsa-2-floor-feet.jpg',
				'ulitsa-3-graffiti.jpg',
			],
		},
		{
			slug: 'priroda',
			title: 'Природа',
			blurb: `Лес и <a href="${POST('puteshestviia-v-rezhime-nabliudatelia-za-zhizniu-i-372')}">Белое море</a> — пейзаж, в котором двое.`,
			photos: ['priroda-1-bog.jpg', 'priroda-2-forest.jpg', 'priroda-3.jpg', 'priroda-4.jpg'],
		},
		{
			slug: 'komnata-hudozhnika',
			title: 'Комната художника',
			blurb: `Студия с <a href="${POST('razobrannost-zheki-rumynskogo-art-khaus-khata-i-288')}">Жекой Румынским</a> — матрас, фен, кирпич, улыбки.`,
			photos: [
				'komnata-1-atelier.jpg',
				'komnata-2-vova-yulia-smile.jpg',
				'komnata-3-mattress.jpg',
				'komnata-4-bridge.jpg',
				'komnata-5-fan.jpg',
			],
		},
		{
			slug: 'portrety',
			title: 'Портреты',
			blurb: 'Лицо, тусовка, futurewear.',
			photos: [
				'portrety-1-bench.jpg',
				'portrety-2-stage.jpg',
				'portrety-3-unemployed.jpg',
			],
		},
	],
};
---

<!doctype html>
<html lang="ru">
	<head>
		<BaseHead
			title={`${album.title} · ${SITE_TITLE}`}
			description="Перформансы, спонтанная импровизация, тело в пространстве — фотоальбом"
			image={ASSET('thumb', 'okno-2-4085.jpg')}
		/>
		<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/photoswipe@5.4.4/dist/photoswipe.css" />
	</head>
	<body>
		<Header />

		<main class="content photos-page">
			<section class="album-hero">
				<div class="hero-top-row">
					<p class="kicker">Альбом</p>
					<p class="meta">{album.total} фотографий · {album.chapters.length} глав</p>
				</div>
				<h1>{album.title}</h1>
				<p class="subtitle">
					Перформансы, спонтанная импровизация, тело в пространстве, как способ <em class="emph">просто быть</em>. В настоящем.
				</p>
			</section>

			<div id="gallery">
				{album.chapters.map((ch, idx) => (
					<section class="chapter-section" id={`ch-${ch.slug}`}>
						<div class="ch-header">
							<div class="text">
								<p class="num">Глава {String(idx + 1).padStart(2, '0')}</p>
								<h2 class="title-toggle" data-target={ch.slug}>
									{ch.title}{ch.photos.length > 3 && <span class="h2-arrow"> ↓</span>}
								</h2>
								<p class="blurb" set:html={ch.blurb}></p>
							</div>
							{ch.photos.length > 3 && (
								<a class="reveal-link" data-target={ch.slug}>
									<span class="arrow">↓</span> <span class="label">открыть главу</span>
								</a>
							)}
						</div>
						<div class="masonry" id={`grid-${ch.slug}`}>
							{ch.photos.map((p) => (
								<a href={ASSET('full', p)} data-pswp-src={ASSET('full', p)} style="--blur:0px">
									<img src={ASSET('thumb', p)} loading="lazy" alt="" />
								</a>
							))}
						</div>
					</section>
				))}
			</div>
		</main>

		<Footer />

		<style is:global>
			/* На /photos/ контент идёт до 1400px — расширяем хедер чтоб бренд+nav
			   оказались на той же сетке. Скоупим через :has() чтобы остальные
			   страницы сайта остались с дефолтным 1100px.
			   Padding обоих контейнеров приводим к 1.25rem (20px), чтобы контент
			   и хедер выравнивались по левой/правой границе колонки. */
			body:has(main.photos-page) .site-header .inner {
				max-width: 1400px;
				padding-left: 0; padding-right: 0;
				/* paddings on .site-header itself give the gutter — 1.25rem horizontal */
			}

			/* Theme-adaptive color tokens for the photos page */
			.photos-page {
				--c-fg: var(--text-dark);
				--c-accent: var(--link);
				--c-muted: var(--muted);
			}

			/* Override the global `main.content { max-width: 620px }` for photos.
			   Photos need horizontal real estate; copy is the rest of the site.
			   Horizontal padding 1.25rem (20px) совпадает с .site-header → бренд
			   и контент колонки выравниваются по одной вертикальной линии. */
			main.content.photos-page {
				max-width: 1400px;
				padding-left: 1.25rem;
				padding-right: 1.25rem;
				padding-top: 0;
			}

			.album-hero {
				max-width: 100%;
				margin: 0 auto;
				padding: 40px 0 8px;
			}
			.album-hero > h1, .album-hero > .subtitle { max-width: 60ch; }
			.hero-top-row {
				display: flex;
				justify-content: space-between;
				align-items: baseline;
				gap: 16px;
				flex-wrap: wrap;
				margin: 0 0 8px;
			}
			.hero-top-row > .kicker, .hero-top-row > .meta { margin: 0; }
			.album-hero .kicker {
				font-family: var(--font-heading, Play, system-ui, sans-serif);
				font-size: 0.75rem;
				letter-spacing: 0.12em;
				text-transform: uppercase;
				color: var(--muted);
				margin: 0 0 8px;
			}
			.album-hero h1 {
				font-family: var(--font-heading, Play, system-ui, sans-serif);
				font-size: 2.25rem;
				margin: 0 0 12px;
				line-height: 1.15;
			}
			.album-hero .subtitle {
				font-size: 1.0625rem;
				color: var(--muted);
				margin: 0 0 14px;
			}
			.album-hero .subtitle .emph {
				font-style: normal;
				font-weight: 700;
				color: var(--c-fg, #1a1a1a);
				background: linear-gradient(180deg, transparent 62%, color-mix(in srgb, var(--text-dark) 18%, transparent) 62%);
				padding: 0 2px;
			}
			.album-hero .meta {
				/* UI-meta — sans-serif (как kicker), не serif body */
				font-family: var(--font-heading, Play, system-ui, sans-serif);
				font-size: 0.8125rem;
				letter-spacing: 0.04em;
				color: var(--muted);
			}

			.chapter-section {
				max-width: 100%;
				margin: 56px 0 16px;
				padding: 0;
			}
			.chapter-section:first-of-type { margin-top: 24px; }
			.chapter-section .ch-header {
				/* Header row занимает полную ширину страницы (как и masonry-сетка
				   ниже), чтобы «открыть главу» было справа на краю. Текст внутри
				   — отдельно ограничен по ширине для читаемости. */
				margin-bottom: 16px;
				display: flex;
				align-items: baseline;
				gap: 16px;
				flex-wrap: wrap;
			}
			.chapter-section .ch-header .text {
				flex: 1 1 auto;
				min-width: 0;
				max-width: 60ch;
			}
			.chapter-section .ch-header .reveal-link { margin-left: auto; }
			.chapter-section .ch-header .num {
				font-family: var(--font-heading, Play, system-ui, sans-serif);
				font-size: 0.75rem;
				letter-spacing: 0.12em;
				text-transform: uppercase;
				color: var(--c-accent, #FF4200);
				margin: 0 0 4px;
			}
			.chapter-section .ch-header h2 {
				font-family: var(--font-heading, Play, system-ui, sans-serif);
				font-size: 1.5rem;
				margin: 0 0 6px;
				cursor: pointer;
				user-select: none;
				display: inline-flex;
				align-items: baseline;
				gap: 8px;
				transition: color .2s ease;
			}
			.chapter-section .ch-header h2 .h2-arrow {
				font-size: 0.875rem;
				color: var(--muted);
				display: inline-block;
				transition: transform .25s ease, color .2s ease;
			}
			.chapter-section .ch-header h2:hover { color: var(--c-accent, #FF4200); }
			.chapter-section .ch-header h2:hover .h2-arrow {
				color: var(--c-accent, #FF4200);
				transform: translateY(2px);
			}
			.chapter-section.open .ch-header h2 .h2-arrow {
				transform: rotate(180deg);
			}
			.chapter-section .ch-header .blurb {
				font-size: 0.9375rem;
				color: var(--muted);
				margin: 0;
			}
			.chapter-section .ch-header .blurb a {
				color: var(--c-fg, #1a1a1a);
				text-decoration: underline;
				text-decoration-thickness: 1px;
				text-underline-offset: 2px;
				transition: color .15s ease;
			}
			.chapter-section .ch-header .blurb a:hover {
				color: var(--c-accent, #FF4200);
			}
			.chapter-section .reveal-link {
				/* UI-action — sans-serif, чтоб не мешалось с serif блюрбом рядом */
				font-family: var(--font-heading, Play, system-ui, sans-serif);
				font-size: 0.75rem;
				letter-spacing: 0.06em;
				text-transform: uppercase;
				flex: 0 0 auto;
				color: var(--muted);
				text-decoration: none;
				border-bottom: 1px solid transparent;
				white-space: nowrap;
				transition: color .2s ease, border-color .2s ease;
				cursor: pointer;
				user-select: none;
			}
			.chapter-section .reveal-link:hover {
				color: var(--c-accent, #FF4200);
				border-color: var(--c-accent, #FF4200);
			}
			.chapter-section .reveal-link .arrow {
				display: inline-block;
				transition: transform .25s ease;
			}
			.chapter-section .reveal-link:hover .arrow { transform: translateY(2px); }
			.chapter-section.open .reveal-link .arrow {
				transform: rotate(180deg);
			}

			.masonry {
				column-count: 3;
				column-gap: 14px;
			}
			@media (min-width: 1500px) { .masonry { column-count: 4; } }
			.masonry > a {
				--blur: 0px;
				break-inside: avoid;
				display: block;
				margin: 0 0 12px;
				border-radius: 4px;
				overflow: hidden;
				background: var(--border-soft);
				position: relative;
			}
			.masonry > a img {
				display: block;
				width: 100%;
				height: auto;
				filter: blur(var(--blur));
				transition: filter .35s ease, transform .3s ease, opacity .2s ease;
				cursor: pointer;
			}
			.masonry > a:hover img {
				filter: none;
				transform: scale(1.01);
			}
			.chapter-section.open .masonry > a img {
				filter: none;
			}

			@media (max-width: 900px) { .masonry { column-count: 2; } }
			@media (max-width: 540px) {
				.masonry { column-count: 1; column-gap: 0; }
				.masonry > a { margin-bottom: 8px; border-radius: 0; }
				.album-hero h1 { font-size: 1.75rem; }
			}

			.pswp { --pswp-bg: #0a0a0a; }
		</style>

		<script is:inline>
			(() => {
				const MAX_BLUR = 14;
				const PSWP_BASE = 'https://cdn.jsdelivr.net/npm/photoswipe@5.4.4/dist';

				function applyVisualBlur(grid) {
					const items = Array.from(grid.querySelectorAll('a'));
					if (items.length === 0) return;
					if (items.length === 1) {
						items[0].style.setProperty('--blur', '0px');
						return;
					}
					const tops = items.map((el) => el.offsetTop);
					const minTop = Math.min.apply(null, tops);
					const ROW_TOL = 30;
					const firstRow = [];
					const rest = [];
					items.forEach((el, i) => {
						if (tops[i] - minTop < ROW_TOL) firstRow.push(el);
						else rest.push({ el: el, top: tops[i], left: el.offsetLeft });
					});
					rest.sort((a, b) => (a.top - b.top) || (a.left - b.left));
					firstRow.forEach((el) => el.style.setProperty('--blur', '0px'));
					rest.forEach((r, i) => {
						const t = rest.length === 1 ? 1 : (i + 1) / rest.length;
						r.el.style.setProperty('--blur', (t * MAX_BLUR).toFixed(1) + 'px');
					});
				}

				async function annotatePswp(grid) {
					const links = Array.from(grid.querySelectorAll('a[data-pswp-src]'));
					await Promise.all(
						links.map(
							(a) =>
								new Promise((resolve) => {
									if (a.dataset.pswpWidth) return resolve();
									const img = new Image();
									img.onload = () => {
										a.dataset.pswpWidth = String(img.naturalWidth);
										a.dataset.pswpHeight = String(img.naturalHeight);
										resolve();
									};
									img.onerror = () => {
										a.dataset.pswpWidth = '1600';
										a.dataset.pswpHeight = '1067';
										resolve();
									};
									img.src = a.dataset.pswpSrc;
								}),
						),
					);
				}

				async function initLightbox(grid) {
					try {
						await annotatePswp(grid);
						const mod = await import(PSWP_BASE + '/photoswipe-lightbox.esm.min.js');
						const PhotoSwipeLightbox = mod.default;
						const lb = new PhotoSwipeLightbox({
							gallery: '#' + grid.id,
							children: 'a',
							pswpModule: () => import(PSWP_BASE + '/photoswipe.esm.min.js'),
							showHideAnimationType: 'fade',
							bgOpacity: 0.95,
						});
						lb.init();
					} catch (err) {
						console.error('PhotoSwipe init failed for', grid.id, err);
					}
				}

				function init() {
					const grids = Array.from(document.querySelectorAll('.masonry'));
					grids.forEach((g) => initLightbox(g));

					const compute = () => grids.forEach((g) => applyVisualBlur(g));
					let timer;
					window.addEventListener('resize', () => {
						clearTimeout(timer);
						timer = setTimeout(compute, 120);
					});

					const allImgs = Array.from(document.querySelectorAll('.masonry img'));
					if (allImgs.length === 0) compute();
					allImgs.forEach((img) => {
						if (img.complete) compute();
						else img.addEventListener('load', compute, { once: true });
					});

					document.querySelectorAll('.chapter-section').forEach((section) => {
						const link = section.querySelector('.reveal-link');
						const label = link ? link.querySelector('.label') : null;
						const title = section.querySelector('.title-toggle');
						const toggle = (e) => {
							e.preventDefault();
							const opened = section.classList.toggle('open');
							if (label) label.textContent = opened ? 'свернуть главу' : 'открыть главу';
						};
						if (link) link.addEventListener('click', toggle);
						if (title) title.addEventListener('click', toggle);
					});
				}

				if (document.readyState === 'loading') {
					document.addEventListener('DOMContentLoaded', init);
				} else {
					init();
				}
			})();
		</script>
	</body>
</html>
