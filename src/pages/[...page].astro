---
import { getCollection } from 'astro:content';
import { getPublishedPosts } from '../lib/blog';
import { excerptOf } from '../lib/excerpt';
import type { GetStaticPaths, PaginateFunction } from 'astro';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE, SITE_AUTHOR_NAME } from '../consts';

export const getStaticPaths: GetStaticPaths = async ({ paginate }: { paginate: PaginateFunction }) => {
	const posts = (await getPublishedPosts())
		.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
	return paginate(posts, { pageSize: 20 });
};

const { page } = Astro.props as any;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Random-post pool — only 2022+ entries (skip early life-tales / 2020-2021).
const allPosts = (await getPublishedPosts())
	.filter((p) => p.data.pubDate.getFullYear() >= 2022)
	.map((p) => ({
		id: p.id,
		title: p.data.title,
		date: p.data.pubDate.toISOString().slice(0, 10),
		hero: p.data.heroImage ?? '',
	}));

const isFirstPage = page.currentPage === 1;
const pageTitle = isFirstPage ? SITE_TITLE : `${SITE_TITLE} — страница ${page.currentPage}`;
/* Для homepage и пагинаций OG-title = имя автора, чтобы в превью TG/Twitter
   нигде не светился внутренний бренд "pio blog". HTML <title> остаётся
   с брендом (нормально для вкладки браузера). */
const ogPageTitle = isFirstPage ? SITE_AUTHOR_NAME : `${SITE_AUTHOR_NAME} — страница ${page.currentPage}`;
---

<!doctype html>
<html lang="ru">
	<head>
		<BaseHead title={pageTitle} description={SITE_DESCRIPTION} ogTitle={ogPageTitle} />
	</head>
	<body>
		<Header />
		{isFirstPage && (
			<section class="home-hero">
				<img src={`${base}/avatar_pio.png`} alt="pio" class="home-avatar" />
				<h1 class="home-title">Вова Луценко</h1>
				<p class="home-subtitle">
					разработчик в прошлом,
					<a class="hidden-link" href={`${base}/tags/${encodeURIComponent('продакт')}/`}>ai-продакт</a> и
					<a class="hidden-link" href={`${base}/tags/${encodeURIComponent('танцы')}/`}>танцор</a>
					в настоящем, maybe
					<a class="hidden-link" href={`${base}/tags/${encodeURIComponent('театр')}/`}>актёр</a>
					в будущем
				</p>
			</section>
		)}
		{isFirstPage && allPosts.length > 0 && (
			<a class="random-post" id="random-post" href="#" aria-label="Открыть случайный пост">
				<div class="thumb" id="random-post-thumb">🎲</div>
				<div class="body">
					<div class="lbl">
						рандомный пост
						<button class="reroll" id="random-post-reroll" type="button" aria-label="перегенерировать" title="перегенерировать">⟳</button>
					</div>
					<div class="ttl" id="random-post-ttl">— загружается…</div>
					<div class="meta" id="random-post-meta"></div>
				</div>
			</a>
			<script
				type="application/json"
				id="random-post-pool"
				set:html={JSON.stringify(allPosts)}
			/>
			<script is:inline>
				(() => {
					const card = document.getElementById('random-post');
					const ttl = document.getElementById('random-post-ttl');
					const meta = document.getElementById('random-post-meta');
					const thumbEl = document.getElementById('random-post-thumb');
					const reroll = document.getElementById('random-post-reroll');
					const poolEl = document.getElementById('random-post-pool');
					if (!card || !ttl || !poolEl) return;
					let pool;
					try { pool = JSON.parse(poolEl.textContent || '[]'); } catch { pool = []; }
					if (!pool.length) { card.style.display = 'none'; return; }

					const fmtDate = (iso) => {
						const d = new Date(iso);
						const months = ['янв','февр','мар','апр','мая','июн','июл','авг','сент','окт','нояб','дек'];
						return d.getDate() + ' ' + months[d.getMonth()] + '. ' + d.getFullYear();
					};
					const base = (document.querySelector('a.brand')?.getAttribute('href') || '/').replace(/\/$/, '');

					let lastIdx = -1;
					function pick() {
						let i = Math.floor(Math.random() * pool.length);
						if (pool.length > 1 && i === lastIdx) i = (i + 1) % pool.length;
						lastIdx = i;
						return pool[i];
					}
					function applyData(p) {
						card.href = base + '/blog/' + p.id + '/';
						ttl.textContent = p.title;
						meta.textContent = fmtDate(p.date);
						if (p.hero) {
							thumbEl.style.backgroundImage = "url('" + p.hero + "')";
							thumbEl.classList.add('has-image');
							thumbEl.textContent = '';
						} else {
							thumbEl.style.backgroundImage = '';
							thumbEl.classList.remove('has-image');
							thumbEl.textContent = '🎲';
						}
					}
					/* Сброс прогресс-заливки (CSS ::before) — toggle класса перезапускает
					   keyframes с 0%. void offsetWidth форсит reflow, иначе браузер
					   сольёт add/remove в один кадр и анимация не рестартанётся. */
					function resetFill() {
						card.classList.add('fill-reset');
						void card.offsetWidth;
						card.classList.remove('fill-reset');
					}
					/* render с лёгкой fade-out → swap → fade-in анимацией */
					function render() {
						const p = pick();
						card.classList.add('rotating');
						setTimeout(() => {
							applyData(p);
							card.classList.remove('rotating');
							resetFill();
						}, 220);
					}
					applyData(pick()); // initial без анимации
					resetFill();       // заливка стартует с 0%

					/* Auto-rotate каждые 8 сек. Пауза если:
					   - hover/focus (читаешь),
					   - пользователь взаимодействовал (клик ⟳),
					   - вкладка скрыта (visibilityState). */
					const ROTATE_MS = 7000;
					/* Прокидываем длительность в CSS, чтобы ::before-fill animation
					   совпадала с JS-таймером по продолжительности. */
					card.style.setProperty('--rotate-ms', ROTATE_MS + 'ms');
					let timer = null;
					let userPaused = false;
					const start = () => {
						card.classList.remove('paused');
						if (timer || userPaused) return;
						if (document.visibilityState === 'hidden') return;
						timer = setInterval(render, ROTATE_MS);
					};
					const stop = () => {
						card.classList.add('paused');
						if (timer) { clearInterval(timer); timer = null; }
					};

					card.addEventListener('mouseenter', stop);
					card.addEventListener('mouseleave', start);
					card.addEventListener('focusin', stop);
					card.addEventListener('focusout', start);
					document.addEventListener('visibilitychange', () => {
						if (document.visibilityState === 'hidden') stop(); else start();
					});

					reroll?.addEventListener('click', (e) => {
						e.preventDefault(); e.stopPropagation();
						render(); // ручной reroll сбрасывает таймер и заливку
						stop(); start();
					});

					start();
				})();
			</script>
		)}
		<main class="feed">
			<ul class="posts-list">
				{page.data.map((post: any) => (
					<li class="post-card">
						<p class="card-date"><FormattedDate date={post.data.pubDate} short /></p>
						<a class="card-link" href={`${base}/blog/${post.id}/`}>{post.data.title}</a>
						{post.body && <p class="card-excerpt">{excerptOf(post.body)}</p>}
						{post.data.heroImage && (
							<a class="card-image" href={`${base}/blog/${post.id}/`} aria-label={post.data.title}>
								<img src={post.data.heroImage} alt="" />
							</a>
						)}
					</li>
				))}
			</ul>

			<nav class="pagination">
				{page.url.prev
					? <a href={page.url.prev}>← свежее</a>
					: <span class="disabled">← свежее</span>}
				<span class="current">страница {page.currentPage} / {page.lastPage}</span>
				{page.url.next
					? <a href={page.url.next}>старее →</a>
					: <span class="disabled">старее →</span>}
			</nav>

			<p class="all-posts-link">
				<a href={`${base}/archive/`}>Все посты &rarr;</a>
			</p>
		</main>
		<Footer />
	</body>
</html>
