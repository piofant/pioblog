---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
import linksData from '../data/cv-links.json';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const pdfPath = `${base}/cv/cv.pdf`;
const pngPath = `${base}/cv/cv-page-1.png`;

type LinkRect = { uri: string; l: number; t: number; w: number; h: number };
const links = linksData as LinkRect[];
---

<!doctype html>
<html lang="ru">
	<head>
		<BaseHead title="CV" description={`Резюме — ${SITE_TITLE}`} />
		<style>
			main.cv-page { max-width: 820px; }
			.cv-page { font-family: var(--font-ui), system-ui, sans-serif; }
			.cv-page .meta { color: var(--muted); font-size: 0.875rem; margin: 0 0 1rem; }
			.cv-page .actions { display: flex; gap: 0.6rem; margin: 0 0 1.25rem; flex-wrap: wrap; }
			.cv-page .btn {
				display: inline-flex; align-items: center; gap: 0.45rem;
				padding: 0.55rem 1rem; border-radius: 4px;
				font-size: 0.9375rem; font-weight: 600;
				text-decoration: none; transition: background 0.15s;
			}
			.cv-page .btn-primary { background: var(--text-dark); color: var(--bg); }
			.cv-page .btn-primary:hover { background: var(--link); color: #fff; }
			.cv-page .btn-ghost {
				background: transparent; color: var(--text-dark);
				border: 1px solid var(--border);
			}
			.cv-page .btn-ghost:hover { border-color: var(--text-dark); }
			.cv-img-clickable {
				position: relative; display: block;
				border: 1px solid var(--border); border-radius: 4px; overflow: hidden;
				background: var(--border-soft);
			}
			.cv-img-clickable img { display: block; width: 100%; height: auto; }
			.cv-img-clickable a.hot {
				position: absolute;
				background: rgba(255, 66, 0, 0);
				transition: background 0.12s, border-bottom 0.12s;
			}
			.cv-img-clickable a.hot:hover {
				background: rgba(255, 66, 0, 0.18);
				border-bottom: 1.5px solid var(--link);
			}
		</style>
	</head>
	<body>
		<Header />
		<main class="content cv-page">
			<h1>CV</h1>
			<p class="meta">Vova Lutsenko · Product Manager · март 2026 · 1 страница, 184 KB · {links.length} кликабельных ссылок</p>
			<div class="actions">
				<a class="btn btn-primary" href={pdfPath} download>⤓ скачать PDF</a>
				<a class="btn btn-ghost" href={pdfPath} target="_blank" rel="noopener">открыть в новой вкладке ↗</a>
			</div>
			<div class="cv-img-clickable">
				<img src={pngPath} alt="CV — page 1" />
				{links.map((l) => (
					<a
						class="hot"
						href={l.uri}
						target={l.uri.startsWith('mailto:') ? undefined : '_blank'}
						rel={l.uri.startsWith('mailto:') ? undefined : 'noopener'}
						style={`left:${l.l}%;top:${l.t}%;width:${l.w}%;height:${l.h}%;`}
					></a>
				))}
			</div>
		</main>
		<Footer />
	</body>
</html>
