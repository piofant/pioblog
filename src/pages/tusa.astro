---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';

const PRES_ID = '1qZTjkXzEI71DS-xRjUyOwCUxneD2lRuS01ARNtuzPKY';
// Default Google Slides embed — keeps the built-in nav controls (prev/next + fullscreen)
const embedUrl = `https://docs.google.com/presentation/d/${PRES_ID}/embed?start=false&loop=false&delayms=3000`;
const editUrl = `https://docs.google.com/presentation/d/${PRES_ID}/edit?usp=sharing`;
---

<!doctype html>
<html lang="ru">
	<head>
		<BaseHead title="презентация" description={`Презентация — ${SITE_TITLE}`} />
		<style>
			main.talk {
				max-width: none;
				padding: 1rem;
			}
			.talk-meta {
				display: flex; align-items: center; justify-content: space-between;
				gap: 1rem; flex-wrap: wrap;
				font-family: var(--font-ui), system-ui, sans-serif;
				font-size: 0.875rem;
				color: var(--muted);
				margin: 0 0 0.75rem;
			}
			.talk-meta a {
				color: var(--text-dark);
				font-weight: 600;
			}
			.talk-meta a:hover { color: var(--link); }
			/* Slide area is 16:9 (=56.25% of width); the player adds a ~40px
			   bottom toolbar. Container height = slide + toolbar — no black bars. */
			.talk-frame {
				position: relative;
				width: min(100%, calc((100vh - 8rem - 40px) * 16 / 9));
				padding-bottom: calc(56.25% + 40px);
				height: 0;
				margin: 0 auto;
				border: 1px solid var(--border);
				border-radius: 4px;
				overflow: hidden;
				background: #fff;
			}
			.talk-frame iframe {
				position: absolute; inset: 0;
				width: 100%; height: 100%;
				border: 0; display: block;
			}
			/* Cover the «Google Slides» watermark in the toolbar */
			.talk-frame::after {
				content: '';
				position: absolute;
				right: 0; bottom: 0;
				width: 124px; height: 40px;
				background: #f1f3f4;
				pointer-events: none;
			}
			.talk-sources {
				width: min(100%, calc((100vh - 8rem) * 16 / 9));
				margin: 1.5rem auto 0;
				padding: 1.25rem 1.5rem;
				border: 1px solid var(--border);
				border-radius: 4px;
				background: var(--border-soft);
				font-family: var(--font-ui), system-ui, sans-serif;
			}
			.talk-sources h3 {
				font-size: 0.8125rem;
				text-transform: uppercase;
				letter-spacing: 0.08em;
				color: var(--muted);
				font-weight: 700;
				margin: 0 0 0.75rem;
			}
			.talk-sources ul { list-style: none; padding: 0; margin: 0; display: grid; gap: 0.5rem; }
			.talk-sources li { font-size: 0.9375rem; line-height: 1.5; }
			.talk-sources li a { color: var(--text-dark); font-weight: 600; }
			.talk-sources li a:hover { color: var(--link); }
			.talk-sources li .desc { color: var(--muted); margin-left: 0.4rem; font-weight: 400; }
		</style>
	</head>
	<body>
		<Header />
		<main class="content talk">
			<div class="talk-meta">
				<span>презентация · стрелки переключения и fullscreen появляются при наведении</span>
				<a href={editUrl} target="_blank" rel="noopener">открыть в Google Slides ↗</a>
			</div>
			<div class="talk-frame">
				<iframe
					src={embedUrl}
					allowfullscreen
					mozallowfullscreen
					webkitallowfullscreen
					title="презентация"
				></iframe>
			</div>

			<aside class="talk-sources">
				<h3>Источники вдохновения</h3>
				<ul>
					<li>
						<a href="https://t.me/thingsiread/7473" target="_blank" rel="noopener">@vitalypavlenko · «общая теория тус»</a>
						<span class="desc">— t.me/thingsiread/7473</span>
					</li>
					<li>
						<a href="https://t.me/random_random_thoughts/267" target="_blank" rel="noopener">@rikachka</a>
						<span class="desc">— t.me/random_random_thoughts/267</span>
					</li>
					<li>
						<a href="https://t.me/explore_feel_analyse/55" target="_blank" rel="noopener">@i_m_kittah</a>
						<span class="desc">— t.me/explore_feel_analyse/55</span>
					</li>
					<li>
						<a href="https://t.me/pioblog/76" target="_blank" rel="noopener">@piofant</a>
						<span class="desc">— t.me/pioblog/76</span>
					</li>
				</ul>
			</aside>
		</main>
	</body>
</html>
