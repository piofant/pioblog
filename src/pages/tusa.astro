---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';

const PRES_ID = '1qZTjkXzEI71DS-xRjUyOwCUxneD2lRuS01ARNtuzPKY';
const embedUrl = `https://docs.google.com/presentation/d/${PRES_ID}/embed?start=false&loop=false&rm=minimal`;
const editUrl = `https://docs.google.com/presentation/d/${PRES_ID}/edit?usp=sharing`;
---

<!doctype html>
<html lang="ru">
	<head>
		<BaseHead title="презентация" description={`Презентация — ${SITE_TITLE}`} />
		<style>
			main.talk {
				max-width: none;
				padding: 1rem;
			}
			.talk-meta {
				display: flex; align-items: center; justify-content: space-between;
				gap: 1rem; flex-wrap: wrap;
				font-family: var(--font-ui), system-ui, sans-serif;
				font-size: 0.875rem;
				color: var(--muted);
				margin: 0 0 0.75rem;
			}
			.talk-meta a {
				color: var(--text-dark);
				font-weight: 600;
			}
			.talk-meta a:hover { color: var(--link); }
			.talk-frame {
				position: relative;
				width: 100%;
				aspect-ratio: 16 / 9;
				max-height: calc(100vh - 9rem);
				border: 1px solid var(--border);
				border-radius: 4px;
				overflow: hidden;
				background: #000;
			}
			.talk-frame iframe {
				width: 100%; height: 100%;
				border: 0; display: block;
			}
		</style>
	</head>
	<body>
		<Header />
		<main class="content talk">
			<div class="talk-meta">
				<span>презентация · стрелки внизу плеера, fullscreen в правом нижнем углу</span>
				<a href={editUrl} target="_blank" rel="noopener">открыть в Google Slides ↗</a>
			</div>
			<div class="talk-frame">
				<iframe
					src={embedUrl}
					allowfullscreen
					mozallowfullscreen
					webkitallowfullscreen
					title="презентация"
				></iframe>
			</div>
		</main>
	</body>
</html>
