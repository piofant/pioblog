---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';

const PRES_ID = '1qZTjkXzEI71DS-xRjUyOwCUxneD2lRuS01ARNtuzPKY';
const embedUrl = `https://docs.google.com/presentation/d/${PRES_ID}/embed?start=false&loop=false&delayms=3000`;
const editUrl = `https://docs.google.com/presentation/d/${PRES_ID}/edit?usp=sharing`;
---

<!doctype html>
<html lang="ru">
	<head>
		<BaseHead title="как перезнакомить 40 айтишников за один вечер" description={`Доклад про контекст знакомства — ${SITE_TITLE}`} image="/img/og/tusa-slide-1.png" />
		<style>
			html, body { overflow-x: hidden; }
			body:has(.talk-spoilers details:not([open])):not(:has(.talk-spoilers details[open])) {
				overflow-y: hidden;
			}

			/* Reserved vertical chrome around the iframe (header + hero + spoiler chip + paddings).
			   Iframe dimensions are derived from this so the whole page fits the viewport. */
			:root { --talk-chrome: 13.5rem; }

			main.talk {
				max-width: none;
				padding: 0.5rem 1rem 0.75rem;
				font-family: var(--font-ui), system-ui, sans-serif;
			}

			/* Hero — compact title block above the slides */
			.talk-hero {
				width: min(100%, calc((100vh - var(--talk-chrome)) * 960 / 569));
				margin: 0.7rem auto 0;
				display: flex;
				align-items: baseline;
				justify-content: space-between;
				gap: 1rem;
				flex-wrap: wrap;
			}
			.talk-hero h1 {
				font-family: var(--font-heading), 'Play', sans-serif;
				font-size: 1.5rem;
				font-weight: 700;
				color: var(--text-dark);
				margin: 0;
				line-height: 1.15;
			}
			.talk-hero .sub {
				color: var(--muted);
				font-size: 0.9375rem;
				margin: 0.15rem 0 0;
				line-height: 1.3;
			}
			.talk-hero .meta {
				font-size: 0.8125rem;
				color: var(--muted-2);
				white-space: nowrap;
			}
			.talk-hero .meta a { color: var(--text-dark); font-weight: 600; }
			.talk-hero .meta a:hover { color: var(--link); }

			/* On taller viewports + lower hero rows, allow more vertical room. */
			@media (min-width: 800px) {
				.talk-hero h1 { font-size: 1.625rem; }
			}
			@media (max-width: 640px) {
				:root { --talk-chrome: 13rem; }
				.talk-hero h1 { font-size: 1.25rem; }
			}

			/* Adaptive iframe — slide aspect 16:9, toolbar overlays the bottom edge.
			   Width = min(container, available_height × 16/9) so it grows as much as
			   viewport allows but never overflows. Aspect-ratio 16:9 ensures no bars. */
			.talk-frame {
				position: relative;
				width: min(100%, calc((100vh - var(--talk-chrome)) * 16 / 9));
				aspect-ratio: 16 / 9;
				max-height: calc(100vh - var(--talk-chrome));
				margin: 0 auto;
				border: 1px solid var(--border);
				border-radius: 4px;
				overflow: hidden;
				background: var(--bg-elevated);
			}
			.talk-frame iframe {
				position: absolute; inset: 0;
				width: 100%; height: 100%;
				border: 0; display: block;
			}
			.talk-frame::after {
				content: '';
				position: absolute;
				right: 0; bottom: 0;
				width: 124px; height: 36px;
				background: #f1f3f4;
				pointer-events: none;
			}

			/* Sources spoiler — single chip below the iframe */
			.talk-spoilers {
				width: min(100%, calc((100vh - var(--talk-chrome)) * 960 / 569));
				margin: 0.6rem auto 0;
			}
			.talk-spoilers details > summary {
				font-size: 0.8125rem;
				text-transform: uppercase;
				letter-spacing: 0.06em;
				color: var(--text);
				font-weight: 600;
				cursor: pointer;
				padding: 0.5rem 0.85rem;
				user-select: none;
				list-style: none;
				display: inline-flex;
				align-items: center;
				gap: 0.4rem;
				background: var(--border-soft);
				border: 1px solid var(--border);
				border-radius: 999px;
				transition: background 0.15s, border-color 0.15s, transform 0.15s;
			}
			.talk-spoilers details > summary::-webkit-details-marker { display: none; }
			.talk-spoilers details > summary::before {
				content: '▸';
				font-size: 0.7rem;
				color: var(--muted);
				transition: transform 0.15s;
			}
			.talk-spoilers details[open] > summary::before { transform: rotate(90deg); }
			.talk-spoilers details > summary:hover {
				background: var(--bg);
				border-color: var(--text);
			}
			.talk-spoilers details[open] > summary {
				background: transparent;
				border-color: transparent;
				padding-left: 0;
			}
			.talk-spoilers details .body {
				margin-top: 0.6rem;
				padding: 1.1rem 1.3rem;
				background: var(--border-soft);
				border: 1px solid var(--border);
				border-radius: 6px;
				font-size: 0.9375rem;
				line-height: 1.6;
			}
			.sources-list { list-style: none; padding: 0; margin: 0; display: grid; gap: 0.5rem; }
			.sources-list li { font-size: 0.9375rem; line-height: 1.5; }
			.sources-list .who { color: var(--text-dark); font-weight: 600; }
			.sources-list .desc { color: var(--muted); margin-left: 0.4rem; font-weight: 400; }
			.sources-list .desc a { color: var(--muted); text-decoration: underline; text-decoration-color: var(--border); text-underline-offset: 2px; }
			.sources-list .desc a:hover { color: var(--link); text-decoration-color: var(--link); }
		</style>
	</head>
	<body>
		<Header />
		<main class="content talk">
			<div class="talk-frame">
				<iframe
					src={embedUrl}
					allowfullscreen
					mozallowfullscreen
					webkitallowfullscreen
					title="презентация"
				></iframe>
			</div>

			<header class="talk-hero">
				<div>
					<h1>как перезнакомить 40 айтишников за один вечер</h1>
					<p class="sub">или что такое «контекст знакомства» и как его создать</p>
				</div>
				<span class="meta">
					~15 мин · доклад · <a href={editUrl} target="_blank" rel="noopener">открыть в Google Slides ↗</a>
				</span>
			</header>

			<div class="talk-spoilers">
				<details>
					<summary>источники вдохновения</summary>
					<div class="body">
						<ul class="sources-list">
							<li>
								<span class="who">@vitalypavlenko · «общая теория тус»</span>
								<span class="desc">— <a href="https://t.me/thingsiread/7473" target="_blank" rel="noopener">t.me/thingsiread/7473</a></span>
							</li>
							<li>
								<span class="who">@rikachka</span>
								<span class="desc">— <a href="https://t.me/random_random_thoughts/267" target="_blank" rel="noopener">t.me/random_random_thoughts/267</a></span>
							</li>
							<li>
								<span class="who">@i_m_kittah</span>
								<span class="desc">— <a href="https://t.me/explore_feel_analyse/55" target="_blank" rel="noopener">t.me/explore_feel_analyse/55</a></span>
							</li>
							<li>
								<span class="who">@piofant</span>
								<span class="desc">— <a href="https://t.me/pioblog/76" target="_blank" rel="noopener">t.me/pioblog/76</a></span>
							</li>
						</ul>
					</div>
				</details>
			</div>
		</main>
	</body>
</html>
