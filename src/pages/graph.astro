---
import { getCollection } from 'astro:content';
import { getPublishedPosts } from '../lib/blog';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const posts = await getPublishedPosts();
const byId = new Map(posts.map((p) => [p.id, p]));

const nodes = posts.map((p) => ({
	id: p.id,
	title: p.data.title,
	date: p.data.pubDate.toISOString().slice(0, 10),
	tags: p.data.tags ?? [],
}));

const edges = new Map<string, { source: string; target: string; kind: string }>();
const LINK_RE = new RegExp(`\\]\\(${base}/blog/([a-z0-9-]+)/?\\)`, 'g');

for (const p of posts) {
	const body = p.body || '';
	for (const m of body.matchAll(LINK_RE)) {
		const target = m[1];
		if (byId.has(target) && target !== p.id) {
			const key = [p.id, target].sort().join('|');
			edges.set(key, { source: p.id, target, kind: 'link' });
		}
	}
}

// Chain-connect posts sharing a tag (distributes pull, avoids hub)
const byTag = new Map<string, string[]>();
for (const p of posts) {
	for (const t of p.data.tags ?? []) {
		if (!byTag.has(t)) byTag.set(t, []);
		byTag.get(t)!.push(p.id);
	}
}
for (const [tag, ids] of byTag) {
	if (ids.length <= 1) continue;
	ids.sort();
	for (let i = 0; i < ids.length - 1; i++) {
		const [a, b] = [ids[i], ids[i + 1]].sort();
		const key = `${a}|${b}|${tag}`;
		edges.set(key, { source: a, target: b, kind: 'tag:' + tag });
	}
}

const graphData = { nodes, links: [...edges.values()] };
const graphJson = JSON.stringify(graphData);

// Try to load tag-categories palette (may not exist — graceful fallback).
// Use import.meta.glob with eager resolution: returns empty object if file is absent,
// avoiding hard build error from a static import to a missing path.
let tagCategoryPalette: Record<string, string> | null = null;
try {
	const modules = import.meta.glob('../data/tag-categories.ts', { eager: true }) as Record<string, any>;
	const mod = Object.values(modules)[0];
	if (mod) {
		const candidate =
			mod.tagColors ??
			mod.tagCategoryColors ??
			mod.default ??
			null;
		if (candidate && typeof candidate === 'object') {
			tagCategoryPalette = candidate as Record<string, string>;
		}
	}
} catch {
	tagCategoryPalette = null;
}
---

<!doctype html>
<html lang="ru">
	<head>
		<BaseHead title="Граф" description={`Граф постов — ${SITE_TITLE}`} />
		<style>
			html, body { margin: 0; padding: 0; height: 100%; overflow: hidden; background: var(--bg); color: var(--text); }
			body { font-family: var(--font-ui), system-ui, sans-serif !important; }
			.site-header { display: none; }
			.topbar { position: fixed; top: 12px; left: 12px; z-index: 10; display: flex; gap: 8px; align-items: center; flex-wrap: wrap; }
			.pill { background: var(--bg-elevated); padding: 6px 8px; border-radius: 8px; border: 1px solid var(--border); display: flex; align-items: center; gap: 6px; box-shadow: 0 2px 8px var(--shadow-sm); }
			.pill a, .pill button { background: var(--bg-elevated); color: var(--text); border: 1px solid var(--border); padding: 6px 12px; border-radius: 4px; cursor: pointer; font: 13px inherit; text-decoration: none; }
			.pill a.home { background: var(--text-dark); color: var(--bg); border-color: var(--text-dark); font-weight: 600; }
			.pill button.mode.active { background: var(--text-dark); color: var(--bg); border-color: var(--text-dark); }
			.pill input { background: var(--bg-elevated); border: 1px solid var(--border); color: var(--text); padding: 6px 10px; border-radius: 4px; width: 240px; font: 13px inherit; }
			.pill input::placeholder { color: var(--muted-2); }
			.pill button.dice { background: var(--bg-elevated); border-color: var(--border); }
			.pill button.dice:hover { background: var(--border-soft); }
			.chips-row { position: fixed; top: 56px; left: 12px; right: 12px; z-index: 9; display: flex; gap: 6px; flex-wrap: wrap; max-width: calc(100vw - 24px); }
			.chip { background: var(--bg-elevated); border: 1px solid var(--border); color: var(--text); padding: 4px 10px; border-radius: 999px; font: 12px inherit; cursor: pointer; user-select: none; display: inline-flex; align-items: center; gap: 6px; transition: background .15s, border-color .15s; }
			.chip:hover { background: var(--border-soft); border-color: var(--muted-2); }
			.chip.active { background: color-mix(in srgb, var(--link) 18%, transparent); border-color: var(--link); color: var(--text-dark); }
			.chip .sw { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
			.chip .count { opacity: .5; font-size: 10px; }
			.hint { position: fixed; bottom: 12px; left: 12px; z-index: 10; font-size: 12px; color: var(--muted); background: var(--bg-elevated); padding: 8px 12px; border-radius: 6px; max-width: 540px; line-height: 1.5; border: 1px solid var(--border); }
			.stage { position: fixed; inset: 0; }
			.info-pill { position: fixed; top: 12px; right: 12px; z-index: 10; background: var(--bg-elevated); border: 1px solid var(--border); padding: 12px 14px; border-radius: 8px; max-width: 400px; font-size: 13px; display: none; box-shadow: 0 4px 16px var(--shadow-md); }
			.info-pill.show { display: block; }
			.info-pill strong { display: block; margin-bottom: 4px; color: var(--text-dark); }
			.info-pill .meta { color: var(--muted); font-size: 11px; margin-top: 6px; line-height: 1.5; }
			.info-pill a { color: var(--link); text-decoration: none; font-size: 11px; margin-top: 6px; display: inline-block; }
			.legend { position: fixed; bottom: 12px; right: 12px; z-index: 10; background: var(--bg-elevated); padding: 10px 12px; border-radius: 8px; font-size: 11px; border: 1px solid var(--border); max-width: 220px; color: var(--muted); line-height: 1.55; }
			.legend strong { color: var(--text-dark); font-weight: 600; }
			.legend .title { font-weight: 600; color: var(--text-dark); margin-bottom: 6px; font-size: 10px; text-transform: uppercase; letter-spacing: 0.5px; opacity: .6; }
			.legend .dot { display: inline-block; width: 8px; height: 8px; border-radius: 50%; background: linear-gradient(90deg,#ff4200,#1e40af,#10b981); vertical-align: middle; margin-right: 4px; }
		</style>
	</head>
	<body>
		<div class="topbar">
			<div class="pill">
				<a href={`${base}/`} class="home">← pio blog</a>
			</div>
			<div class="pill">
				<button id="mode-posts" class="mode active">посты</button>
				<button id="mode-tags" class="mode">теги</button>
			</div>
			<div class="pill">
				<input id="search" type="text" placeholder="поиск по заголовку…" />
				<button id="dice" class="dice" title="случайный пост">🎲 случайный</button>
				<button id="reset">сброс</button>
			</div>
		</div>

		<div class="chips-row" id="chips"></div>

		<div class="info-pill" id="info"></div>
		<div class="legend" id="legend">
			<div class="title">легенда</div>
			<div><span class="dot"></span><strong>цвет</strong> — категория тега</div>
			<div style="margin-top:4px;"><strong>размер ноды</strong> — число связей</div>
			<div style="margin-top:4px; opacity:.7;">наведи — соседи подсветятся</div>
		</div>
		<div class="stage" id="stage"></div>
		<div class="hint">
			<strong>{nodes.length} постов · {graphData.links.length} связей</strong>. drag — pan · wheel — zoom · click — фокус · чипы сверху — мульти-фильтр по тегам
		</div>

		<script src="https://cdn.jsdelivr.net/npm/force-graph@1.49.5/dist/force-graph.min.js" is:inline></script>
		<script define:vars={{ DATA: graphData, BASE: base, EXTERNAL_PALETTE: tagCategoryPalette }} is:inline>
			const neighbors = new Map();
			DATA.nodes.forEach(n => neighbors.set(n.id, new Set()));
			DATA.links.forEach(l => {
				neighbors.get(l.source)?.add(l.target);
				neighbors.get(l.target)?.add(l.source);
			});
			const metaTags = new Set(['whois','intro','история','истории','жизнипост','мысли','telegram']);
			DATA.nodes.forEach(n => {
				n.deg = neighbors.get(n.id)?.size || 0;
				n.primaryTag = (n.tags || []).find(t => !metaTags.has(t)) || 'разное';
			});
			// Inline fallback palette — used if EXTERNAL_PALETTE (from src/data/tag-categories.ts) is missing.
			const fallbackPalette = [
				['продакт','#ff4200'], ['карьера','#e11d48'], ['школа жизни','#f59e0b'],
				['вуз','#1e40af'], ['трипы','#10b981'], ['рефлексия','#8b5cf6'],
				['психология','#a855f7'], ['нетворкинг','#06b6d4'], ['безумие','#ec4899'],
				['театр','#f43f5e'], ['ии','#0ea5e9'], ['анонс','#14b8a6'],
				['боты','#22c55e'], ['танцы','#d946ef'], ['творчество','#eab308'],
				['жизнь','#84cc16'], ['друзья','#f97316'], ['мнения','#64748b'],
			];
			const tagColor = new Map(fallbackPalette);
			// Layer external palette on top — its colors win when present.
			if (EXTERNAL_PALETTE && typeof EXTERNAL_PALETTE === 'object') {
				for (const [k, v] of Object.entries(EXTERNAL_PALETTE)) {
					if (typeof v === 'string') tagColor.set(k, v);
				}
			}
			function colorByTag(n) { return tagColor.get(n.primaryTag) || '#777'; }

			const stage = document.getElementById('stage');
			const info = document.getElementById('info');
			const legend = document.getElementById('legend');
			const chipsEl = document.getElementById('chips');
			const getCss = (name) => getComputedStyle(document.documentElement).getPropertyValue(name).trim();
			let current = null;
			let mode = 'posts';                    // 'posts' | 'tags'
			const selectedTags = new Set();        // multi-select primary-tag chips
			let searchQuery = '';                  // lowercased title query (live)
			let hoverId = null;                    // hovered node id (for neighbor highlight)

			// Build tag co-occurrence graph
			const tagGraph = (() => {
				const tagCounts = new Map();
				const cooc = new Map();  // 'tagA|tagB' (sorted) → count
				for (const n of DATA.nodes) {
					const ts = (n.tags || []).filter(t => !metaTags.has(t));
					for (const t of ts) tagCounts.set(t, (tagCounts.get(t) || 0) + 1);
					for (let i = 0; i < ts.length; i++) {
						for (let j = i + 1; j < ts.length; j++) {
							const key = [ts[i], ts[j]].sort().join('|');
							cooc.set(key, (cooc.get(key) || 0) + 1);
						}
					}
				}
				const tagNodes = [...tagCounts.entries()].map(([id, count]) => ({
					id, count, deg: 0, isTag: true, primaryTag: id,
				}));
				const tagLinks = [];
				for (const [key, weight] of cooc) {
					const [a, b] = key.split('|');
					tagLinks.push({ source: a, target: b, weight, kind: 'cooc' });
				}
				// degree
				for (const l of tagLinks) {
					const a = tagNodes.find(n => n.id === l.source);
					const b = tagNodes.find(n => n.id === l.target);
					if (a) a.deg += 1;
					if (b) b.deg += 1;
				}
				return { nodes: tagNodes, links: tagLinks };
			})();

			function showInfo(node) {
				if (!node) { info.classList.remove('show'); return; }
				info.innerHTML = '<strong>' + node.title + '</strong>' +
					'<div class="meta">' + node.date + ' · связей: ' + node.deg +
					(node.tags && node.tags.length ? '<br>теги: ' + node.tags.join(', ') : '') + '</div>' +
					'<a href="' + BASE + '/blog/' + node.id + '/">открыть пост →</a>';
				info.classList.add('show');
			}

			// Returns the set of node ids that pass the current chip+search filter.
			// When no filters are active → returns null (meaning "all visible, normal styling").
			function computeMatchSet() {
				const tagsActive = selectedTags.size > 0;
				const queryActive = searchQuery.length > 0;
				if (!tagsActive && !queryActive) return null;
				const out = new Set();
				for (const n of DATA.nodes) {
					const tagOk = !tagsActive || selectedTags.has(n.primaryTag);
					const qOk = !queryActive || (n.title || '').toLowerCase().includes(searchQuery);
					if (tagOk && qOk) out.add(n.id);
				}
				return out;
			}

			// Re-render the chips row from current selectedTags state.
			function renderChips() {
				const counts = new Map();
				DATA.nodes.forEach(n => counts.set(n.primaryTag, (counts.get(n.primaryTag) || 0) + 1));
				// sort: selected first, then by count desc
				const entries = [...counts.entries()]
					.sort((a, b) => {
						const sa = selectedTags.has(a[0]) ? 1 : 0;
						const sb = selectedTags.has(b[0]) ? 1 : 0;
						if (sa !== sb) return sb - sa;
						return b[1] - a[1];
					});
				chipsEl.innerHTML = entries.map(([t, c]) => {
					const active = selectedTags.has(t) ? ' active' : '';
					const sw = tagColor.get(t) || '#777';
					return '<button class="chip' + active + '" data-tag="' + t.replace(/"/g, '&quot;') + '">' +
						'<span class="sw" style="background:' + sw + '"></span>' +
						t + '<span class="count">' + c + '</span></button>';
				}).join('');
				chipsEl.querySelectorAll('.chip').forEach(el => {
					el.addEventListener('click', () => toggleTag(el.dataset.tag));
				});
			}

			function toggleTag(tag) {
				if (selectedTags.has(tag)) selectedTags.delete(tag);
				else selectedTags.add(tag);
				renderChips();
				applyFilters();
			}

			function clearAllFilters() {
				selectedTags.clear();
				searchQuery = '';
				const searchEl = document.getElementById('search');
				if (searchEl) searchEl.value = '';
				renderChips();
				applyFilters();
			}

			// Apply current filter state by refreshing the existing graph's styling
			// (no full rebuild → no layout reset, snappy UX).
			function applyFilters() {
				if (!current || mode !== 'posts') return;
				current.nodeColor(nodeColorFn).linkColor(linkColorFn).linkWidth(linkWidthFn);
				if (typeof current.refresh === 'function') current.refresh();
			}

			function focusNode(id) {
				const node = DATA.nodes.find(n => n.id === id);
				if (!node || !current) return;
				if (current.centerAt && typeof node.x === 'number') {
					current.centerAt(node.x, node.y, 800);
					if (current.zoom) current.zoom(3, 800);
				}
			}

			// --- styling functions (read shared state, used by both initial build and applyFilters) ---
			function isMatch(id, matchSet) {
				return !matchSet || matchSet.has(id);
			}
			function nodeColorFn(n) {
				const matchSet = computeMatchSet();
				const matched = isMatch(n.id, matchSet);
				// Hover-neighbor highlight overrides filter dim only when no chip/search filter active.
				if (hoverId) {
					const isHover = n.id === hoverId;
					const isNeighbor = neighbors.get(hoverId)?.has(n.id);
					if (!isHover && !isNeighbor) return matched ? 'rgba(60,60,60,0.5)' : 'rgba(40,40,40,0.3)';
				}
				if (!matched) return 'rgba(60,60,60,0.35)';
				return colorByTag(n);
			}
			function linkColorFn(l) {
				const matchSet = computeMatchSet();
				const s = typeof l.source === 'object' ? l.source.id : l.source;
				const t = typeof l.target === 'object' ? l.target.id : l.target;
				const sMatch = isMatch(s, matchSet);
				const tMatch = isMatch(t, matchSet);
				const dim = !(sMatch && tMatch);
				if (hoverId) {
					const touchesHover = s === hoverId || t === hoverId;
					if (!touchesHover) return dim ? 'rgba(50,50,50,0.05)' : 'rgba(80,80,80,0.08)';
					// hovered link
					return l.kind === 'link' ? 'rgba(255,200,120,0.85)' : 'rgba(255,200,120,0.55)';
				}
				if (dim) return 'rgba(80,80,80,0.05)';
				return l.kind === 'link' ? 'rgba(210,210,210,0.3)' : 'rgba(120,180,255,0.1)';
			}
			function linkWidthFn(l) {
				const s = typeof l.source === 'object' ? l.source.id : l.source;
				const t = typeof l.target === 'object' ? l.target.id : l.target;
				if (hoverId && (s === hoverId || t === hoverId)) {
					return l.kind === 'link' ? 1.4 : 1.0;
				}
				return l.kind === 'link' ? 0.6 : 0.2;
			}

			function renderPosts() {
				const visibleNodes = DATA.nodes;
				const visibleLinks = DATA.links.map(l => ({
					source: typeof l.source === 'object' ? l.source.id : l.source,
					target: typeof l.target === 'object' ? l.target.id : l.target,
					kind: l.kind,
				}));

				renderChips();
				legend.style.display = '';

				current = ForceGraph()(stage)
					.graphData({ nodes: visibleNodes, links: visibleLinks })
					.backgroundColor('#0a0a0a')
					.nodeRelSize(4)
					.nodeVal(n => 1 + Math.min(n.deg, 20) * 0.6)
					.nodeColor(nodeColorFn)
					.linkColor(linkColorFn)
					.linkWidth(linkWidthFn)
					.nodeCanvasObjectMode(() => 'after')
					.nodeCanvasObject((node, ctx, scale) => {
						const matchSet = computeMatchSet();
						const matched = isMatch(node.id, matchSet);
						if (!matched && !hoverId) return;
						if (hoverId && node.id !== hoverId && !neighbors.get(hoverId)?.has(node.id)) return;
						const label = node.primaryTag;
						if (scale < 0.6 && node.deg < 3) return;
						const fontSize = Math.min(11, 8 / scale * 1.3);
						ctx.font = fontSize + 'px sans-serif';
						ctx.fillStyle = matched ? getCss('--graph-text') : getCss('--muted-2');
						ctx.textAlign = 'center';
						ctx.textBaseline = 'middle';
						const nodeR = 4 * Math.sqrt(1 + Math.min(node.deg, 20) * 0.6);
						ctx.fillText(label, node.x, node.y + nodeR + fontSize * 0.7);
					})
					.onNodeHover(node => {
						hoverId = node ? node.id : null;
						showInfo(node);
						if (typeof current.refresh === 'function') current.refresh();
						stage.style.cursor = node ? 'pointer' : 'default';
					})
					.onNodeClick(n => focusNode(n.id))
					.nodeLabel(n => n.title)
					.cooldownTicks(250)
					.warmupTicks(80);

				setTimeout(() => {
					try {
						current.d3Force('charge').strength(-180);
						current.d3Force('link').distance(l => l.kind === 'link' ? 45 : 30);
						current.d3ReheatSimulation();
					} catch(e) {}
				}, 50);
				current.onEngineStop(() => { current.zoomToFit(400, 60); });
			}

			function renderTags() {
				stage.innerHTML = '';
				legend.style.display = 'none';
				chipsEl.style.display = 'none';
				const { nodes, links } = tagGraph;
				current = ForceGraph()(stage)
					.graphData({
						nodes: nodes.map(n => ({...n})),
						links: links.map(l => ({...l})),
					})
					.backgroundColor(getCss('--bg'))
					.nodeRelSize(8)
					.nodeVal(n => 1 + Math.sqrt(n.count || 1) * 3)
					.nodeColor(n => colorByTag({ primaryTag: n.id }))
					.linkColor(() => getCss('--graph-link'))
					.linkWidth(l => Math.min(0.8 + l.weight * 0.4, 4))
					.nodeCanvasObjectMode(() => 'after')
					.nodeCanvasObject((node, ctx, scale) => {
						const fontSize = Math.max(11, Math.min(20, 10 + Math.sqrt(node.count) * 1.5)) / Math.max(scale, 0.6);
						ctx.font = '700 ' + fontSize + 'px sans-serif';
						ctx.fillStyle = getCss('--text-dark');
						ctx.textAlign = 'center';
						ctx.textBaseline = 'middle';
						const r = 8 * Math.sqrt(1 + Math.sqrt(node.count || 1) * 3);
						ctx.fillText(node.id + ' (' + node.count + ')', node.x, node.y + r + fontSize * 0.7);
					})
					.onNodeHover(node => {
						if (!node) { info.classList.remove('show'); return; }
						info.innerHTML = '<strong>#' + node.id + '</strong>' +
							'<div class="meta">' + node.count + ' постов · соседних тем: ' + node.deg + '</div>';
						info.classList.add('show');
					})
					.onNodeClick(node => {
						window.location.href = BASE + '/tags/' + encodeURIComponent(node.id) + '/';
					})
					.nodeLabel(n => n.id + ' (' + n.count + ' постов)')
					.cooldownTicks(200)
					.warmupTicks(80);

				setTimeout(() => {
					try {
						current.d3Force('charge').strength(-400);
						current.d3Force('link').distance(60);
						current.d3ReheatSimulation();
					} catch(e) {}
				}, 50);
				current.onEngineStop(() => { current.zoomToFit(500, 80); });
			}

			function render() {
				stage.innerHTML = '';
				if (mode === 'tags') return renderTags();
				chipsEl.style.display = '';
				return renderPosts();
			}

			document.getElementById('search').addEventListener('input', (e) => {
				searchQuery = e.target.value.trim().toLowerCase();
				applyFilters();
			});
			document.getElementById('reset').addEventListener('click', () => {
				clearAllFilters();
			});
			document.getElementById('dice').addEventListener('click', () => {
				if (mode !== 'posts') return;
				const matchSet = computeMatchSet();
				const pool = matchSet
					? DATA.nodes.filter(n => matchSet.has(n.id))
					: DATA.nodes;
				if (!pool.length) return;
				const pick = pool[Math.floor(Math.random() * pool.length)];
				window.location.href = BASE + '/blog/' + pick.id + '/';
			});

			document.getElementById('mode-posts').addEventListener('click', () => {
				if (mode === 'posts') return;
				mode = 'posts';
				document.getElementById('mode-posts').classList.add('active');
				document.getElementById('mode-tags').classList.remove('active');
				render();
			});
			document.getElementById('mode-tags').addEventListener('click', () => {
				if (mode === 'tags') return;
				mode = 'tags';
				document.getElementById('mode-tags').classList.add('active');
				document.getElementById('mode-posts').classList.remove('active');
				render();
			});

			render();
			window.addEventListener('themechange', () => { if (current) render(); });
		</script>
	</body>
</html>
