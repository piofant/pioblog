---
import { getCollection } from 'astro:content';
import { getPublishedPosts } from '../../lib/blog';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const posts = (await getPublishedPosts()).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const byYear: Record<string, typeof posts> = {};
for (const p of posts) {
	const y = String(p.data.pubDate.getFullYear());
	(byYear[y] ??= []).push(p);
}
const years = Object.keys(byYear).sort((a, b) => Number(b) - Number(a));
---

<!doctype html>
<html lang="ru">
	<head>
		<BaseHead title="Архив" description={`Все посты — ${SITE_TITLE}`} />
	</head>
	<body>
		<Header />
		<main class="content archive-page">
			{years.map((y) => (
				<>
					<h2>{y}</h2>
					<ul class="archive-list">
						{byYear[y].map((post) => (
							<li>
								<span class="date"><FormattedDate date={post.data.pubDate} short /></span>
								<a href={`${base}/blog/${post.id}/`}>{post.data.title}</a>
							</li>
						))}
					</ul>
				</>
			))}
		</main>
		<Footer />
	</body>
</html>
